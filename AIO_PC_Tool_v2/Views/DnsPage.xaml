<Page x:Class="AIO_PC_Tool_v2.Views.DnsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DNS Manager" Background="#0A0A0A" FontFamily="Segoe UI">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock FontSize="32" FontWeight="Bold">
                        <Run Text="DNS" Foreground="White"/>
                        <Run Text=" Manager" Foreground="#DC2626"/>
                    </TextBlock>
                    <TextBlock Text="Optimize your network with fast, secure DNS servers" FontSize="14" Foreground="#606060" Margin="0,8,0,0"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#0F0F0F" CornerRadius="12" Padding="20,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Current:" FontSize="13" Foreground="#505050" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ActiveDns" Text="Default (ISP)" FontSize="14" Foreground="#DC2626" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Status Banner -->
            <Border Grid.Row="1" CornerRadius="12" Padding="20,16" Margin="0,0,0,28">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#3B82F620" Offset="0"/>
                        <GradientStop Color="#3B82F610" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#3B82F630" CornerRadius="8" Width="40" Height="40" Margin="0,0,16,0">
                        <TextBlock Text="ℹ" FontSize="18" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="Select a DNS provider below" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Text="DNS changes are applied instantly. You may need to restart your browser." FontSize="12" Foreground="#606060" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- DNS Options Grid -->
            <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,24">
                <!-- Cloudflare -->
                <Border x:Name="Card_Cloudflare" Background="#0F0F0F" CornerRadius="14" Padding="22" Margin="0,0,12,12" Cursor="Hand" Tag="Cloudflare" MouseLeftButtonUp="DnsCard_Click" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="48" Height="48" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F97316" Offset="0"/>
                                        <GradientStop Color="#EA580C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="☁" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Cloudflare" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                <Border Background="#22C55E30" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                    <TextBlock Text="RECOMMENDED" FontSize="8" Foreground="#22C55E" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Fastest DNS with strong privacy. Best for gaming and general use." FontSize="12" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="1.1.1.1" FontSize="13" Foreground="#808080" FontFamily="Consolas"/>
                                <TextBlock Text="1.0.0.1" FontSize="13" Foreground="#606060" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Google -->
                <Border x:Name="Card_Google" Background="#0F0F0F" CornerRadius="14" Padding="22" Margin="6,0,6,12" Cursor="Hand" Tag="Google" MouseLeftButtonUp="DnsCard_Click" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="48" Height="48" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4285F4" Offset="0"/>
                                        <GradientStop Color="#3B78E7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="G" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Google DNS" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                <Border Background="#3B82F630" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                    <TextBlock Text="RELIABLE" FontSize="8" Foreground="#3B82F6" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Highly reliable with global infrastructure. Easy to remember addresses." FontSize="12" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="8.8.8.8" FontSize="13" Foreground="#808080" FontFamily="Consolas"/>
                                <TextBlock Text="8.8.4.4" FontSize="13" Foreground="#606060" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- OpenDNS -->
                <Border x:Name="Card_OpenDNS" Background="#0F0F0F" CornerRadius="14" Padding="22" Margin="12,0,0,12" Cursor="Hand" Tag="OpenDNS" MouseLeftButtonUp="DnsCard_Click" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="48" Height="48" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#22C55E" Offset="0"/>
                                        <GradientStop Color="#16A34A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🛡" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="OpenDNS" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                <Border Background="#22C55E30" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                    <TextBlock Text="FAMILY SAFE" FontSize="8" Foreground="#22C55E" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Built-in phishing protection and parental controls available." FontSize="12" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="208.67.222.222" FontSize="13" Foreground="#808080" FontFamily="Consolas"/>
                                <TextBlock Text="208.67.220.220" FontSize="13" Foreground="#606060" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Quad9 -->
                <Border x:Name="Card_Quad9" Background="#0F0F0F" CornerRadius="14" Padding="22" Margin="0,0,12,12" Cursor="Hand" Tag="Quad9" MouseLeftButtonUp="DnsCard_Click" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="48" Height="48" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="9" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Quad9" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                <Border Background="#8B5CF630" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                    <TextBlock Text="SECURE" FontSize="8" Foreground="#8B5CF6" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Privacy-focused with malware blocking. Non-profit organization." FontSize="12" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="9.9.9.9" FontSize="13" Foreground="#808080" FontFamily="Consolas"/>
                                <TextBlock Text="149.112.112.112" FontSize="13" Foreground="#606060" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- AdGuard -->
                <Border x:Name="Card_AdGuard" Background="#0F0F0F" CornerRadius="14" Padding="22" Margin="6,0,6,12" Cursor="Hand" Tag="AdGuard" MouseLeftButtonUp="DnsCard_Click" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="48" Height="48" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#67B279" Offset="0"/>
                                        <GradientStop Color="#4E9C5F" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🚫" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="AdGuard" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                <Border Background="#67B27930" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                    <TextBlock Text="AD BLOCKER" FontSize="8" Foreground="#67B279" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Blocks ads and trackers at DNS level. Great for ad-free browsing." FontSize="12" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="94.140.14.14" FontSize="13" Foreground="#808080" FontFamily="Consolas"/>
                                <TextBlock Text="94.140.15.15" FontSize="13" Foreground="#606060" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Default -->
                <Border x:Name="Card_Default" Background="#0F0F0F" CornerRadius="14" Padding="22" Margin="12,0,0,12" Cursor="Hand" Tag="Default" MouseLeftButtonUp="DnsCard_Click" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="48" Height="48" CornerRadius="12" Background="#2A2A2A">
                                <TextBlock Text="↺" FontSize="22" Foreground="#707070" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Reset Default" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                <Border Background="#50505030" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                    <TextBlock Text="ISP DEFAULT" FontSize="8" Foreground="#707070" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Reset DNS to automatic (ISP default). Use if experiencing issues." FontSize="12" Foreground="#707070" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Automatic" FontSize="13" Foreground="#808080" FontFamily="Consolas"/>
                                <TextBlock Text="(ISP Provided)" FontSize="13" Foreground="#606060" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </UniformGrid>
            
            <!-- Apply Button -->
            <Border Grid.Row="3" HorizontalAlignment="Center">
                <Button x:Name="ApplyButton" Click="Apply_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="40,14" IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌐" FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Text="Apply Selected DNS" FontWeight="SemiBold" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
