<Page x:Class="AIO_PC_Tool_v2.Views.DnsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DNS Manager" Background="#0D0D0D">
    
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="DNS Manager" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Change your DNS servers for faster browsing and better privacy" FontSize="14" Foreground="#A3A3A3" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- DNS Providers -->
        <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="ProvidersList"/>
        </ScrollViewer>
        
        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Reset to Automatic" Click="Reset_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="Apply DNS" Click="Apply_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Page>
