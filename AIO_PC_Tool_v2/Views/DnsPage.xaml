<Page x:Class="AIO_PC_Tool_v2.Views.DnsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DNS Manager" Background="#0A0A0A">
    
    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock FontSize="28" FontWeight="Bold">
                    <Run Text="DNS" Foreground="White"/>
                    <Run Text="Manager" Foreground="#DC2626"/>
                </TextBlock>
                <TextBlock Text="Select a DNS provider and click Apply — requires Administrator" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="▲ Active:" Foreground="#22C55E" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="ActiveDns" Text="Default" Foreground="#22C55E" FontSize="12" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <!-- DNS Grid -->
        <UniformGrid Grid.Row="1" Columns="3" Rows="2">
            <Border x:Name="Card_Cloudflare" Background="#141414" CornerRadius="8" Padding="20" Margin="0,0,10,10" Cursor="Hand" MouseLeftButtonUp="DnsCard_Click" Tag="Cloudflare">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,0,10,0"/>
                        <TextBlock Text="Cloudflare" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        <Border Background="#F59E0B" CornerRadius="4" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Fastest" FontSize="9" Foreground="Black" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Fastest public DNS, privacy-focused" FontSize="11" Foreground="#606060" Margin="0,8,0,16"/>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Primary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="1.1.1.1" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Secondary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="1.0.0.1" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <Border x:Name="Card_Google" Background="#141414" CornerRadius="8" Padding="20" Margin="5,0,5,10" Cursor="Hand" MouseLeftButtonUp="DnsCard_Click" Tag="Google">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#3B82F6" Margin="0,0,10,0"/>
                        <TextBlock Text="Google" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        <Border Background="#3B82F6" CornerRadius="4" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Popular" FontSize="9" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Reliable with global infrastructure" FontSize="11" Foreground="#606060" Margin="0,8,0,16"/>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Primary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="8.8.8.8" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Secondary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="8.8.4.4" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <Border x:Name="Card_OpenDNS" Background="#141414" CornerRadius="8" Padding="20" Margin="10,0,0,10" Cursor="Hand" MouseLeftButtonUp="DnsCard_Click" Tag="OpenDNS">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#8B5CF6" Margin="0,0,10,0"/>
                        <TextBlock Text="OpenDNS" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Content filtering &amp; phishing protection" FontSize="11" Foreground="#606060" Margin="0,8,0,16"/>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Primary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="208.67.222.222" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Secondary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="208.67.220.220" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <Border x:Name="Card_Quad9" Background="#141414" CornerRadius="8" Padding="20" Margin="0,10,10,0" Cursor="Hand" MouseLeftButtonUp="DnsCard_Click" Tag="Quad9">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,10,0"/>
                        <TextBlock Text="Quad9" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        <Border Background="#22C55E" CornerRadius="4" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Secure" FontSize="9" Foreground="Black" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Security-focused, blocks malicious domains" FontSize="11" Foreground="#606060" Margin="0,8,0,16"/>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Primary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="9.9.9.9" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Secondary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="149.112.112.112" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <Border x:Name="Card_AdGuard" Background="#141414" CornerRadius="8" Padding="20" Margin="5,10,5,0" Cursor="Hand" MouseLeftButtonUp="DnsCard_Click" Tag="AdGuard">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#06B6D4" Margin="0,0,10,0"/>
                        <TextBlock Text="AdGuard" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        <Border Background="#06B6D4" CornerRadius="4" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Ad Block" FontSize="9" Foreground="Black" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Blocks ads and trackers system-wide" FontSize="11" Foreground="#606060" Margin="0,8,0,16"/>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Primary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="94.140.14.14" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Secondary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="94.140.15.15" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <Border x:Name="Card_Default" Background="#141414" CornerRadius="8" Padding="20" Margin="10,10,0,0" Cursor="Hand" MouseLeftButtonUp="DnsCard_Click" Tag="Default">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#505050" Margin="0,0,10,0"/>
                        <TextBlock Text="Default (ISP)" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        <Border Background="#505050" CornerRadius="4" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Default" FontSize="9" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Use your internet provider's DNS" FontSize="11" Foreground="#606060" Margin="0,8,0,16"/>
                    
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Primary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="Auto" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Secondary" FontSize="10" Foreground="#505050"/>
                            <TextBlock Text="Auto" FontSize="12" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </UniformGrid>
        
        <!-- Apply Button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
            <Button x:Name="ApplyButton" Content="Apply DNS" Click="Apply_Click" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False"/>
            <TextBlock x:Name="StatusText" Text="Select a DNS provider above to enable Apply" FontSize="12" Foreground="#606060" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>
    </Grid>
</Page>
