<Page x:Class="AIO_PC_Tool_v2.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Settings" Background="Transparent">
    
    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <StackPanel MaxWidth="700">
            
            <!-- Header -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Customize your AIO PC Tool experience" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
            
            <!-- ═══════════════════════════════════════════════════════════════════════════════
                 THEME SECTION
                 ═══════════════════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="THEME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12" Opacity="0.8"/>
            <Border Style="{StaticResource PremiumCard}" Margin="0,0,0,24">
                <StackPanel>
                    
                    <!-- Dark/Light Mode Toggle -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Dark Mode" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Use dark color scheme with black background" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" 
                                      IsChecked="{Binding IsDarkMode}" 
                                      Style="{StaticResource PremiumToggle}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Border Height="1" Background="{DynamicResource BorderSubtle}" Margin="0,0,0,20"/>
                    
                    <!-- Accent Color Picker -->
                    <StackPanel>
                        <TextBlock Text="Accent Color" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Choose your preferred accent color for the interface" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        
                        <!-- Color Options Grid -->
                        <ItemsControl ItemsSource="{Binding AccentColors}" Margin="0,16,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,12,12" 
                                            Padding="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.SelectAccentColorCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding Name}"
                                            ToolTip="{Binding Name}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <!-- Selection Ring -->
                                                                <Border x:Name="selectionRing"
                                                                        Width="52" Height="52"
                                                                        CornerRadius="26"
                                                                        BorderThickness="2"
                                                                        BorderBrush="Transparent"
                                                                        Background="Transparent"/>
                                                                <!-- Color Circle -->
                                                                <Border Width="44" Height="44"
                                                                        CornerRadius="22"
                                                                        Background="{Binding PreviewColor}">
                                                                    <!-- Checkmark for selected -->
                                                                    <TextBlock Text="✓" 
                                                                               FontSize="18" 
                                                                               FontWeight="Bold"
                                                                               Foreground="White"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                </Border>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter TargetName="selectionRing" Property="BorderBrush" Value="{Binding PreviewColor}"/>
                                                                </DataTrigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="selectionRing" Property="BorderBrush" Value="{DynamicResource TextMuted}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Current Selection Label -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Current: " FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock Text="{Binding SelectedAccentColor}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- ═══════════════════════════════════════════════════════════════════════════════
                 BEHAVIOR SECTION
                 ═══════════════════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="BEHAVIOR" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12" Opacity="0.8"/>
            <Border Style="{StaticResource PremiumCard}" Margin="0,0,0,24">
                <StackPanel>
                    
                    <!-- Start with Windows -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start with Windows" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Launch application when Windows starts" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" 
                                      IsChecked="{Binding StartWithWindows}" 
                                      Style="{StaticResource PremiumToggle}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Border Height="1" Background="{DynamicResource BorderSubtle}" Margin="0,0,0,16"/>
                    
                    <!-- Minimize to Tray -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Minimize to Tray" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Minimize to system tray instead of taskbar" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" 
                                      IsChecked="{Binding MinimizeToTray}" 
                                      Style="{StaticResource PremiumToggle}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Border Height="1" Background="{DynamicResource BorderSubtle}" Margin="0,0,0,16"/>
                    
                    <!-- Auto-detect on Startup -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-detect Tweaks on Startup" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Automatically scan system state when app opens" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" 
                                      IsChecked="{Binding AutoDetectOnStartup}" 
                                      Style="{StaticResource PremiumToggle}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- ═══════════════════════════════════════════════════════════════════════════════
                 ABOUT SECTION
                 ═══════════════════════════════════════════════════════════════════════════════ -->
            <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12" Opacity="0.8"/>
            <Border Style="{StaticResource PremiumCard}" Margin="0,0,0,24">
                <StackPanel>
                    
                    <!-- App Info -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="48" Height="48" CornerRadius="12" Background="{DynamicResource AccentPrimary}">
                            <TextBlock Text="AIO" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="JGoode's AIO PC Tool" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimary}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Version " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding AppVersion}" FontSize="12" Foreground="{DynamicResource AccentPrimary}" FontWeight="SemiBold"/>
                                <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock Text="{Binding BuildDate}" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <TextBlock Text="Professional Windows 11 optimization, privacy, and performance tool. All tweaks are 100% safe and reversible." 
                               FontSize="13" 
                               Foreground="{DynamicResource TextSecondary}" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,20"/>
                    
                    <!-- Features list -->
                    <Border Background="{DynamicResource BackgroundInput}" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Built with" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Border CornerRadius="4" Background="{DynamicResource BackgroundCardHover}" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text=".NET 8" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                                <Border CornerRadius="4" Background="{DynamicResource BackgroundCardHover}" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="WPF" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                                <Border CornerRadius="4" Background="{DynamicResource BackgroundCardHover}" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="MVVM" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                                <Border CornerRadius="4" Background="{DynamicResource BackgroundCardHover}" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="CommunityToolkit" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="View on GitHub" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                        <Button Content="Check for Updates" Style="{StaticResource SecondaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Safety Notice -->
            <Border Background="{DynamicResource SuccessGreenLight}" CornerRadius="12" Padding="16" Margin="0,0,0,32">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SuccessGreen}" VerticalAlignment="Top" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Safety Guaranteed" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource SuccessGreen}"/>
                        <TextBlock Text="All tweaks in this application are 100% safe, thoroughly tested, and completely reversible. No registry keys are ever deleted." 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondary}" 
                                   TextWrapping="Wrap" 
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Page>
