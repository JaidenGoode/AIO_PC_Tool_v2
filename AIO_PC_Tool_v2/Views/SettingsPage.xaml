<Page x:Class="AIO_PC_Tool_v2.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="#0A0A0A">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,30" MaxWidth="800">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock FontSize="28" FontWeight="Bold">
                    <Run Text="App" Foreground="White"/>
                    <Run Text="Settings" Foreground="#DC2626"/>
                </TextBlock>
                <TextBlock Text="Customize appearance and preferences" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
            </StackPanel>
            
            <!-- Appearance Section -->
            <Border Grid.Row="1" Background="#141414" CornerRadius="10" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="🎨" FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Text="APPEARANCE" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <!-- Accent Color -->
                    <TextBlock Text="Accent Color" FontSize="13" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border x:Name="ColorRed" Width="36" Height="36" CornerRadius="18" Background="#DC2626" Margin="0,0,8,0" Cursor="Hand" BorderThickness="3" BorderBrush="#DC2626" MouseLeftButtonUp="AccentColor_Click" Tag="Red"/>
                        <Border x:Name="ColorBlue" Width="36" Height="36" CornerRadius="18" Background="#3B82F6" Margin="0,0,8,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Blue"/>
                        <Border x:Name="ColorGreen" Width="36" Height="36" CornerRadius="18" Background="#22C55E" Margin="0,0,8,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Green"/>
                        <Border x:Name="ColorPurple" Width="36" Height="36" CornerRadius="18" Background="#8B5CF6" Margin="0,0,8,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Purple"/>
                        <Border x:Name="ColorPink" Width="36" Height="36" CornerRadius="18" Background="#EC4899" Margin="0,0,8,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Pink"/>
                        <Border x:Name="ColorOrange" Width="36" Height="36" CornerRadius="18" Background="#F97316" Margin="0,0,8,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Orange"/>
                        <Border x:Name="ColorTeal" Width="36" Height="36" CornerRadius="18" Background="#14B8A6" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Teal"/>
                    </StackPanel>
                    
                    <!-- Theme Toggle -->
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Dark Mode" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="Use dark theme throughout the application" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#22C55E" CornerRadius="12" Padding="8,4">
                            <TextBlock Text="ON" FontSize="10" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- About Section -->
            <Border Grid.Row="2" Background="#141414" CornerRadius="10" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="ℹ" FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Text="ABOUT" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse Width="48" Height="48" Fill="#DC2626"/>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="18" FontWeight="Bold">
                                <Run Text="JGoode" Foreground="White"/>
                                <Run Text="'s" Foreground="#DC2626"/>
                                <Run Text=" AIO PC Tool" Foreground="White"/>
                            </TextBlock>
                            <TextBlock Text="Version 4.0.0" FontSize="12" Foreground="#606060" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <TextBlock Text="A professional Windows optimization tool built with WPF and .NET 8. Features safe, fully reversible system tweaks, real-time hardware monitoring, system cleaner, DNS manager, and powerful utilities." FontSize="12" Foreground="#808080" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    
                    <Border Background="#0A0A0A" CornerRadius="8" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Built with" FontSize="10" Foreground="#505050" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="• WPF (.NET 8)" FontSize="11" Foreground="#606060"/>
                                <TextBlock Text="• LibreHardwareMonitor" FontSize="11" Foreground="#606060"/>
                                <TextBlock Text="• CommunityToolkit.Mvvm" FontSize="11" Foreground="#606060"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Features" FontSize="10" Foreground="#505050" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="• 30+ Safe Tweaks" FontSize="11" Foreground="#606060"/>
                                <TextBlock Text="• Real-time Monitoring" FontSize="11" Foreground="#606060"/>
                                <TextBlock Text="• System Cleaner" FontSize="11" Foreground="#606060"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Credits -->
            <Border Grid.Row="3" Background="#141414" CornerRadius="10" Padding="24">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Created by JaidenGoode" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Text="© 2024 All rights reserved" FontSize="11" Foreground="#505050" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Border Background="#1A1A1A" CornerRadius="6" Padding="12,8" Margin="0,0,8,0" Cursor="Hand">
                            <TextBlock Text="GitHub" FontSize="11" Foreground="#808080"/>
                        </Border>
                        <Border Background="#5865F2" CornerRadius="6" Padding="12,8" Cursor="Hand">
                            <TextBlock Text="Discord" FontSize="11" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
