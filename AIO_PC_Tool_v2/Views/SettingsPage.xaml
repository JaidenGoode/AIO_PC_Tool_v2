<Page x:Class="AIO_PC_Tool_v2.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="#0A0A0A">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,30" MaxWidth="900">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock FontSize="28" FontWeight="Bold">
                    <Run Text="App" Foreground="White"/>
                    <Run Text="Settings" Foreground="#DC2626"/>
                </TextBlock>
                <TextBlock Text="Customize appearance, preferences and view app info" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
            </StackPanel>
            
            <!-- Appearance Section -->
            <Border Grid.Row="1" Background="#141414" CornerRadius="10" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <TextBlock Text="🎨" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="APPEARANCE" FontSize="11" Foreground="#505050" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Accent Color -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Accent Color" FontSize="14" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Choose your accent color for the interface" FontSize="12" Foreground="#606060" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="ColorRed" Width="44" Height="44" CornerRadius="22" Background="#DC2626" Margin="0,0,10,0" Cursor="Hand" BorderThickness="3" BorderBrush="#DC2626" MouseLeftButtonUp="AccentColor_Click" Tag="Red">
                                <TextBlock Text="✓" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <Border x:Name="ColorBlue" Width="44" Height="44" CornerRadius="22" Background="#3B82F6" Margin="0,0,10,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Blue"/>
                            <Border x:Name="ColorGreen" Width="44" Height="44" CornerRadius="22" Background="#22C55E" Margin="0,0,10,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Green"/>
                            <Border x:Name="ColorPurple" Width="44" Height="44" CornerRadius="22" Background="#8B5CF6" Margin="0,0,10,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Purple"/>
                            <Border x:Name="ColorPink" Width="44" Height="44" CornerRadius="22" Background="#EC4899" Margin="0,0,10,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Pink"/>
                            <Border x:Name="ColorOrange" Width="44" Height="44" CornerRadius="22" Background="#F97316" Margin="0,0,10,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Orange"/>
                            <Border x:Name="ColorTeal" Width="44" Height="44" CornerRadius="22" Background="#14B8A6" Margin="0,0,10,0" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Teal"/>
                            <Border x:Name="ColorCyan" Width="44" Height="44" CornerRadius="22" Background="#06B6D4" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent" MouseLeftButtonUp="AccentColor_Click" Tag="Cyan"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Dark Mode Toggle -->
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="16">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Dark Mode" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Currently using dark theme (recommended for reduced eye strain)" FontSize="12" Foreground="#606060" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#22C55E" CornerRadius="12" Padding="12,6">
                                <TextBlock Text="ENABLED" FontSize="10" Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- About Section -->
            <Border Grid.Row="2" Background="#141414" CornerRadius="10" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <TextBlock Text="ℹ" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ABOUT" FontSize="11" Foreground="#505050" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- App Info -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Background="#DC2626" CornerRadius="12" Width="64" Height="64">
                            <TextBlock Text="⚡" FontSize="32" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="20" FontWeight="Bold">
                                <Run Text="JGoode" Foreground="White"/>
                                <Run Text="'s" Foreground="#DC2626"/>
                                <Run Text=" AIO PC Tool" Foreground="White"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Background="#22C55E" CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="v4.0.0" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text=" • Built with WPF .NET 8" FontSize="12" Foreground="#606060" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <TextBlock Text="A professional Windows optimization and gaming performance tool. Features safe, fully reversible system tweaks, advanced cleaner with DirectX shader cache support, real-time hardware monitoring, DNS manager, and powerful system utilities." FontSize="13" Foreground="#808080" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="22"/>
                    
                    <!-- Stats Grid -->
                    <UniformGrid Columns="4" Margin="0,0,0,0">
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="35+" FontSize="24" Foreground="#DC2626" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Safe Tweaks" FontSize="11" Foreground="#606060" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="25+" FontSize="24" Foreground="#3B82F6" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Clean Categories" FontSize="11" Foreground="#606060" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="8" FontSize="24" Foreground="#22C55E" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Utilities" FontSize="11" Foreground="#606060" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="6" FontSize="24" Foreground="#8B5CF6" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="DNS Providers" FontSize="11" Foreground="#606060" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
            
            <!-- Credits -->
            <Border Grid.Row="3" Background="#141414" CornerRadius="10" Padding="24">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Created by JaidenGoode" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Text="© 2024-2025 All rights reserved" FontSize="12" Foreground="#505050" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1A1A1A" CornerRadius="6" Padding="16,10" Margin="0,0,10,0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⭐" Margin="0,0,8,0"/>
                                <TextBlock Text="GitHub" FontSize="12" Foreground="#909090"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#5865F2" CornerRadius="6" Padding="16,10" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬" Margin="0,0,8,0"/>
                                <TextBlock Text="Discord" FontSize="12" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
