<Page x:Class="AIO_PC_Tool_v2.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Settings" Background="Transparent">
    
    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Customize the appearance of the application" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600">
                
                <Border Background="{DynamicResource BackgroundCard}" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Dark Mode" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Use dark theme for the application" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsDarkMode}" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <TextBlock Text="Accent Color" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                        <ComboBox ItemsSource="{Binding AccentColors}" SelectedItem="{Binding SelectedAccent}" Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                
                <Border Background="{DynamicResource BackgroundCard}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,16"/>
                        <TextBlock Text="JGoode's AIO PC Tool v2" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Version 4.0.0" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        <TextBlock Text="A professional Windows optimization tool built with WPF and .NET 8." FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,16,0,0"/>
                        <TextBlock Text="Created by JaidenGoode" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
