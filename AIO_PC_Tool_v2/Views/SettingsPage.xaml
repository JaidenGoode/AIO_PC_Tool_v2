<Page x:Class="AIO_PC_Tool_v2.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="#0D0D0D">
    
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Application settings and information" FontSize="14" Foreground="#A3A3A3" Margin="0,4,0,0"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel MaxWidth="600">
                
                <!-- About -->
                <Border Background="#1A1A1A" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold" Foreground="#737373" Margin="0,0,0,16"/>
                        <TextBlock Text="JGoode's AIO PC Tool v2" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Version 4.0.0" FontSize="13" Foreground="#A3A3A3" Margin="0,4,0,0"/>
                        <TextBlock Text="A professional Windows optimization tool built with WPF and .NET 8. Features safe, reversible system tweaks, real-time hardware monitoring, system cleaner, DNS manager, and more." FontSize="13" Foreground="#A3A3A3" TextWrapping="Wrap" Margin="0,16,0,0"/>
                        
                        <Border Background="#252525" CornerRadius="8" Padding="16" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Built with" FontSize="11" FontWeight="Bold" Foreground="#737373" Margin="0,0,0,8"/>
                                <TextBlock Text="- WPF (.NET 8)" FontSize="13" Foreground="#A3A3A3"/>
                                <TextBlock Text="- LibreHardwareMonitor" FontSize="13" Foreground="#A3A3A3"/>
                                <TextBlock Text="- CommunityToolkit.Mvvm" FontSize="13" Foreground="#A3A3A3"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="Created by JaidenGoode" FontSize="12" Foreground="#737373" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
