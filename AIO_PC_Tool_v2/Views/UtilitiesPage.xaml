<Page x:Class="AIO_PC_Tool_v2.Views.UtilitiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Utilities" Background="Transparent">
    
    <Page.DataContext>
        <vm:UtilitiesViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Utilities" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Quick access to system tools and commands" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Featured: Chris Titus Tech Utility -->
        <Border Grid.Row="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="#3B82F6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="Star" Width="24" Height="24" Foreground="#FFD700" VerticalAlignment="Center"/>
                        <TextBlock Text="RECOMMENDED" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Chris Titus Tech Windows Utility" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Comprehensive Windows optimization tool with debloat, tweaks, and more. Opens in admin PowerShell." 
                               FontSize="13" Foreground="White" Opacity="0.9" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="500"/>
                </StackPanel>
                
                <Button Grid.Column="1" 
                        Content="LAUNCH" 
                        Command="{Binding RunUtilityCommand}"
                        CommandParameter="ctt-utility"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Background="White"
                        Foreground="#7C3AED"
                        FontWeight="Bold"
                        Padding="24,12"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Category Filter -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <ComboBox ItemsSource="{Binding Categories}" 
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      Width="180"
                      materialDesign:HintAssist.Hint="Category"/>
        </StackPanel>
        
        <!-- Utilities Grid -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredUtilities}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BackgroundCard}" CornerRadius="10" Padding="16" Margin="0,0,12,12" Cursor="Hand"
                                Visibility="{Binding Id, Converter={StaticResource HideCttConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                    <Border Background="{StaticResource BackgroundCardHover}" CornerRadius="4" Padding="6,2" Margin="0,6,0,0" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource TextSecondary}" FontWeight="Medium"/>
                                    </Border>
                                </StackPanel>
                                
                                <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Button Content="Run" 
                                            Command="{Binding DataContext.RunUtilityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding Id}"
                                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                            Background="{StaticResource AccentPrimary}"
                                            Foreground="White"
                                            Padding="16,6"/>
                                    
                                    <Border Visibility="{Binding RequiresRestart, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Background="#F9731620" CornerRadius="4" Padding="6,4" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Restart" FontSize="10" Foreground="#F97316" FontWeight="Medium"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{StaticResource BackgroundCard}" CornerRadius="8" Padding="12" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Information" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" 
                             Style="{StaticResource MaterialDesignCircularProgressBar}" Width="20" Height="20" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
