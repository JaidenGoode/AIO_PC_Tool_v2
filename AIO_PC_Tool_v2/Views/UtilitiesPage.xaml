<Page x:Class="AIO_PC_Tool_v2.Views.UtilitiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Utilities" Background="Transparent">
    
    <Page.DataContext>
        <vm:UtilitiesViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Utilities" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="System repair tools and maintenance utilities" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Featured: Chris Titus Tech Utility -->
        <Border Grid.Row="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="#3B82F6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="FEATURED" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" Opacity="0.8"/>
                    <TextBlock Text="Chris Titus Tech Utility" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    <TextBlock Text="The ultimate Windows utility script for debloating, installing programs, and optimizing your system. Runs the official CTT winutil script with admin privileges." 
                               FontSize="13" Foreground="White" Opacity="0.9" TextWrapping="Wrap" MaxWidth="500" Margin="0,8,0,0"/>
                </StackPanel>
                
                <Button Grid.Column="1" Content="Launch CTT Utility" 
                        Command="{Binding RunChrisTitusCommand}"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Background="White" Foreground="#7C3AED"
                        FontWeight="Bold" Padding="24,12"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Utilities Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Utilities}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BackgroundCard}" CornerRadius="10" Padding="16" Margin="0,0,8,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                        <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0" Background="{StaticResource BackgroundCardHover}">
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1" Content="Run"
                                        Command="{Binding DataContext.RunUtilityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        VerticalAlignment="Center" Padding="16,8"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
