<Page x:Class="AIO_PC_Tool_v2.Views.UtilitiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Utilities" Background="#0D0D0D">
    
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Utilities" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="System repair tools and maintenance utilities" FontSize="14" Foreground="#A3A3A3" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Chris Titus Tech -->
        <Border Grid.Row="1" CornerRadius="12" Padding="20" Margin="0,0,0,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="#3B82F6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="FEATURED" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.8"/>
                    <TextBlock Text="Chris Titus Tech Utility" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    <TextBlock Text="The ultimate Windows utility script for debloating, installing programs, and optimizing your system." FontSize="13" Foreground="White" Opacity="0.9" TextWrapping="Wrap" MaxWidth="500" Margin="0,8,0,0"/>
                </StackPanel>
                
                <Button Grid.Column="1" Content="Launch CTT Utility" Click="LaunchCTT_Click" Background="White" Foreground="#7C3AED" FontWeight="Bold" Padding="24,12" VerticalAlignment="Center" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        
        <!-- Utilities Grid -->
        <ScrollViewer Grid.Row="2">
            <StackPanel x:Name="UtilitiesList"/>
        </ScrollViewer>
    </Grid>
</Page>
