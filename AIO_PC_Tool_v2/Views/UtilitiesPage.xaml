<Page x:Class="AIO_PC_Tool_v2.Views.UtilitiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Utilities" Background="#0A0A0A">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#0A0A0A" Padding="40,30,40,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock FontSize="28" FontWeight="Bold">
                        <Run Text="System" Foreground="White"/>
                        <Run Text="Utilities" Foreground="#DC2626"/>
                    </TextBlock>
                    <TextBlock Text="Repair tools, maintenance utilities and system diagnostics" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Chris Titus Tech Featured Card -->
                <Border Grid.Row="1" CornerRadius="12" Padding="24,20" Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="#3B82F6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Icon -->
                        <Border Grid.Column="0" Background="#FFFFFF20" CornerRadius="10" Width="56" Height="56" Margin="0,0,20,0">
                            <TextBlock Text="⚡" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Chris Titus Tech Utility" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                <Border Background="#FFFFFF30" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="FEATURED" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="The ultimate Windows utility for debloating, optimization, and installing essential programs" FontSize="12" Foreground="#FFFFFFCC" Margin="0,6,0,0"/>
                        </StackPanel>
                        
                        <!-- Button -->
                        <Button Grid.Column="2" Click="LaunchCTT_Click" Background="White" Foreground="#7C3AED" FontWeight="Bold" Padding="24,12" VerticalAlignment="Center" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Launch CTT" FontWeight="Bold"/>
                                <TextBlock Text=" →" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Utilities Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40,0,40,30">
            <StackPanel x:Name="UtilitiesList"/>
        </ScrollViewer>
    </Grid>
</Page>
