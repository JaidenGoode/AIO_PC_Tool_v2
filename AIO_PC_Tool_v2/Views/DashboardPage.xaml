<Page x:Class="AIO_PC_Tool_v2.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Dashboard" Background="Transparent">
    
    <Page.DataContext>
        <vm:DashboardViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Real-time system monitoring" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Hardware Cards -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2">
            <!-- CPU Card -->
            <Border Background="{DynamicResource BackgroundCard}" CornerRadius="12" Padding="20" Margin="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cpu64Bit" Width="24" Height="24" Foreground="{DynamicResource AccentPrimary}"/>
                        <TextBlock Text="CPU" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="{Binding SystemInfo.Cpu.Model}" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SystemInfo.Cpu.Usage, StringFormat={}{0:F0}%}" FontSize="48" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}" Margin="0,8,0,0"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="2" Text="{Binding SystemInfo.Cpu.Temperature, StringFormat=Temperature: {0:F0}C}" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                </Grid>
            </Border>
            
            <!-- GPU Card -->
            <Border Background="{DynamicResource BackgroundCard}" CornerRadius="12" Padding="20" Margin="12,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Gpu" Width="24" Height="24" Foreground="{DynamicResource AccentSecondary}"/>
                        <TextBlock Text="GPU" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="{Binding SystemInfo.Gpu.Model}" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SystemInfo.Gpu.Usage, StringFormat={}{0:F0}%}" FontSize="48" FontWeight="Bold" Foreground="{DynamicResource AccentSecondary}" Margin="0,8,0,0"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="2" Text="{Binding SystemInfo.Gpu.Temperature, StringFormat=Temperature: {0:F0}C}" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                </Grid>
            </Border>
            
            <!-- RAM Card -->
            <Border Background="{DynamicResource BackgroundCard}" CornerRadius="12" Padding="20" Margin="0,12,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Memory" Width="24" Height="24" Foreground="{DynamicResource SuccessGreen}"/>
                        <TextBlock Text="RAM" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="{Binding SystemInfo.Ram.UsagePercent, StringFormat={}{0:F0}%}" FontSize="48" FontWeight="Bold" Foreground="{DynamicResource SuccessGreen}"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="2" FontSize="12" Foreground="{DynamicResource TextSecondary}">
                        <Run Text="{Binding SystemInfo.Ram.UsedGb, StringFormat={}{0:F1}}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding SystemInfo.Ram.TotalGb, StringFormat={}{0:F1} GB}"/>
                    </TextBlock>
                </Grid>
            </Border>
            
            <!-- Disk Card -->
            <Border Background="{DynamicResource BackgroundCard}" CornerRadius="12" Padding="20" Margin="12,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Harddisk" Width="24" Height="24" Foreground="{DynamicResource InfoBlue}"/>
                        <TextBlock Text="DISK" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16">
                        <TextBlock Text="{Binding SystemInfo.Disk.UsagePercent, StringFormat={}{0:F0}%}" FontSize="48" FontWeight="Bold" Foreground="{DynamicResource InfoBlue}"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="2" FontSize="12" Foreground="{DynamicResource TextSecondary}">
                        <Run Text="{Binding SystemInfo.Disk.UsedGb, StringFormat={}{0:F0}}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding SystemInfo.Disk.TotalGb, StringFormat={}{0:F0} GB}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
