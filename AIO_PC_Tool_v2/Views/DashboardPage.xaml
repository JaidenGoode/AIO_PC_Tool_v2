<Page x:Class="AIO_PC_Tool_v2.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="#0A0A0A">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock FontSize="28" FontWeight="Bold">
                    <Run Text="System" Foreground="White"/>
                    <Run Text="Dashboard" Foreground="#DC2626"/>
                </TextBlock>
                <TextBlock Text="Real-time overview and controls" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
            </StackPanel>
            
            <!-- Active Tweaks Banner -->
            <Border Grid.Row="1" Background="#141414" CornerRadius="8" Padding="20,16" Margin="0,0,0,20">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚡" Foreground="#F59E0B" FontSize="16" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Foreground="White" FontSize="14">
                                <Run x:Name="ActiveTweaksCount" Text="0" FontWeight="Bold" Foreground="#F59E0B"/>
                                <Run Text=" / 40 tweaks active"/>
                            </TextBlock>
                            <TextBlock Text="Optimizations applied to your system" FontSize="11" Foreground="#606060"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Manage →" HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" Padding="16,8"/>
                </Grid>
            </Border>
            
            <!-- Hardware Section Title -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,12">
                <TextBlock Text="⬡" Foreground="#DC2626" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="HARDWARE" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
            </StackPanel>
            
            <!-- Hardware Cards -->
            <UniformGrid Grid.Row="3" Columns="4" Margin="0,0,0,20">
                <Border Background="#141414" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="⬡" Foreground="#505050" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="PROCESSOR" FontSize="10" Foreground="#505050" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="CpuModel" Text="Loading..." FontSize="13" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="CpuDetails" Text="-- Cores • -- GHz" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#141414" CornerRadius="8" Padding="16" Margin="5,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="⬡" Foreground="#505050" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="GRAPHICS" FontSize="10" Foreground="#505050" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="GpuModel" Text="Loading..." FontSize="13" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="GpuDetails" Text="-- GB" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#141414" CornerRadius="8" Padding="16" Margin="5,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="⬡" Foreground="#505050" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="MEMORY" FontSize="10" Foreground="#505050" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="RamTotal" Text="0 GB" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock x:Name="RamUsed" Text="0 GB in use" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#141414" CornerRadius="8" Padding="16" Margin="10,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="⬡" Foreground="#505050" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="STORAGE" FontSize="10" Foreground="#505050" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="DiskTotal" Text="0 GB" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DiskFree" Text="0 GB free" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            
            <!-- Live Usage and Temps -->
            <Grid Grid.Row="4" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Live Usage -->
                <Border Grid.Column="0" Background="#141414" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="⬡" Foreground="#DC2626" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="LIVE USAGE" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <!-- CPU Usage -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU" Foreground="#808080" FontSize="12"/>
                            <Grid Grid.Column="1" Margin="12,0">
                                <Border Background="#1F1F1F" CornerRadius="3" Height="6"/>
                                <Border x:Name="CpuBar" Background="#DC2626" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                            </Grid>
                            <TextBlock x:Name="CpuPercent" Grid.Column="2" Text="0%" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- RAM Usage -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RAM" Foreground="#808080" FontSize="12"/>
                            <Grid Grid.Column="1" Margin="12,0">
                                <Border Background="#1F1F1F" CornerRadius="3" Height="6"/>
                                <Border x:Name="RamBar" Background="#DC2626" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                            </Grid>
                            <TextBlock x:Name="RamPercent" Grid.Column="2" Text="0%" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- GPU Usage -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GPU" Foreground="#808080" FontSize="12"/>
                            <Grid Grid.Column="1" Margin="12,0">
                                <Border Background="#1F1F1F" CornerRadius="3" Height="6"/>
                                <Border x:Name="GpuBar" Background="#DC2626" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                            </Grid>
                            <TextBlock x:Name="GpuPercent" Grid.Column="2" Text="0%" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Disk Usage -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DISK" Foreground="#808080" FontSize="12"/>
                            <Grid Grid.Column="1" Margin="12,0">
                                <Border Background="#1F1F1F" CornerRadius="3" Height="6"/>
                                <Border x:Name="DiskBar" Background="#DC2626" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                            </Grid>
                            <TextBlock x:Name="DiskPercent" Grid.Column="2" Text="0%" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Temperatures -->
                <Border Grid.Column="1" Background="#141414" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="🌡" Foreground="#DC2626" FontSize="12" Margin="0,0,8,0"/>
                            <TextBlock Text="TEMPERATURES" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <Border BorderBrush="#1F1F1F" BorderThickness="0,0,0,1" Padding="0,12">
                            <Grid>
                                <TextBlock Text="CPU Temp" Foreground="#808080" FontSize="12"/>
                                <TextBlock x:Name="CpuTemp" Text="--°C" Foreground="White" FontSize="12" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                        <Border BorderBrush="#1F1F1F" BorderThickness="0,0,0,1" Padding="0,12">
                            <Grid>
                                <TextBlock Text="GPU Temp" Foreground="#808080" FontSize="12"/>
                                <TextBlock x:Name="GpuTemp" Text="--°C" Foreground="White" FontSize="12" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                        <Border Padding="0,12">
                            <Grid>
                                <TextBlock Text="CPU Peak" Foreground="#808080" FontSize="12"/>
                                <TextBlock x:Name="CpuPeak" Text="--°C" Foreground="White" FontSize="12" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Quick Access -->
            <StackPanel Grid.Row="5">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="⬡" Foreground="#DC2626" FontSize="12" Margin="0,0,8,0"/>
                    <TextBlock Text="QUICK ACCESS" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                </StackPanel>
                
                <UniformGrid Columns="6">
                    <Border Background="#141414" CornerRadius="8" Padding="20,24" Margin="0,0,8,0" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🧹" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Cleaner" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Remove junk" FontSize="10" Foreground="#505050" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#141414" CornerRadius="8" Padding="20,24" Margin="4,0" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Tweaks" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Optimize Windows" FontSize="10" Foreground="#505050" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#141414" CornerRadius="8" Padding="20,24" Margin="4,0" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🔧" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Utilities" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="System tools" FontSize="10" Foreground="#505050" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#141414" CornerRadius="8" Padding="20,24" Margin="4,0" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🌐" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="DNS" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="DNS settings" FontSize="10" Foreground="#505050" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#141414" CornerRadius="8" Padding="20,24" Margin="4,0" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="↺" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Restore" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="System protection" FontSize="10" Foreground="#505050" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#141414" CornerRadius="8" Padding="20,24" Margin="8,0,0,0" Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Settings" FontSize="12" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="App preferences" FontSize="10" Foreground="#505050" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
