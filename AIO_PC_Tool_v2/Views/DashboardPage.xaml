<Page x:Class="AIO_PC_Tool_v2.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="#0D0D0D">
    
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Real-time system monitoring" FontSize="14" Foreground="#A3A3A3" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Hardware Cards -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2">
            <!-- CPU Card -->
            <Border Background="#1A1A1A" CornerRadius="12" Padding="20" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="CPU" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="CpuUsage" Text="0%" FontSize="48" FontWeight="Bold" Foreground="#DC2626" Margin="0,16,0,0"/>
                    <TextBlock x:Name="CpuTemp" Text="Temperature: --" FontSize="12" Foreground="#A3A3A3" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- GPU Card -->
            <Border Background="#1A1A1A" CornerRadius="12" Padding="20" Margin="12,0,0,12">
                <StackPanel>
                    <TextBlock Text="GPU" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="GpuUsage" Text="0%" FontSize="48" FontWeight="Bold" Foreground="#EF4444" Margin="0,16,0,0"/>
                    <TextBlock x:Name="GpuTemp" Text="Temperature: --" FontSize="12" Foreground="#A3A3A3" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- RAM Card -->
            <Border Background="#1A1A1A" CornerRadius="12" Padding="20" Margin="0,12,12,0">
                <StackPanel>
                    <TextBlock Text="RAM" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="RamUsage" Text="0%" FontSize="48" FontWeight="Bold" Foreground="#22C55E" Margin="0,16,0,0"/>
                    <TextBlock x:Name="RamDetails" Text="0 / 0 GB" FontSize="12" Foreground="#A3A3A3" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Disk Card -->
            <Border Background="#1A1A1A" CornerRadius="12" Padding="20" Margin="12,12,0,0">
                <StackPanel>
                    <TextBlock Text="DISK" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="DiskUsage" Text="0%" FontSize="48" FontWeight="Bold" Foreground="#3B82F6" Margin="0,16,0,0"/>
                    <TextBlock x:Name="DiskDetails" Text="0 / 0 GB" FontSize="12" Foreground="#A3A3A3" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
