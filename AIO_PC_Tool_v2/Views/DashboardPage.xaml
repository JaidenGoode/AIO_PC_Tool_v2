<Page x:Class="AIO_PC_Tool_v2.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="#0A0A0A" FontFamily="Segoe UI">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock FontSize="32" FontWeight="Bold">
                        <Run Text="Welcome," Foreground="White"/>
                        <Run Text=" Commander" Foreground="#DC2626"/>
                    </TextBlock>
                    <TextBlock Text="Your PC optimization command center • Monitor, Clean, Optimize" FontSize="14" Foreground="#606060" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentTime" Text="00:00" FontSize="36" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="CurrentDate" Text="Loading..." FontSize="13" Foreground="#505050" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- Hardware Monitor Cards -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
                <!-- CPU Card -->
                <Border Background="#0F0F0F" CornerRadius="16" Padding="24" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="44" Height="44" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#2563EB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⚙" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="CPU" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                                <TextBlock Text="PROCESSOR" FontSize="9" Foreground="#303030"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock x:Name="CpuUsage" Text="0%" FontSize="36" Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="CpuName" Text="Loading..." FontSize="11" Foreground="#606060" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        
                        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="4" Height="6" Margin="0,0,0,12">
                            <Border x:Name="CpuBar" Background="#3B82F6" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <TextBlock Text="🌡" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock x:Name="CpuTemp" Text="--°C" FontSize="13" Foreground="#707070"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- GPU Card -->
                <Border Background="#0F0F0F" CornerRadius="16" Padding="24" Margin="6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="44" Height="44" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#22C55E" Offset="0"/>
                                        <GradientStop Color="#16A34A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🎮" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="GPU" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                                <TextBlock Text="GRAPHICS" FontSize="9" Foreground="#303030"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock x:Name="GpuUsage" Text="0%" FontSize="36" Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="GpuName" Text="Loading..." FontSize="11" Foreground="#606060" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        
                        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="4" Height="6" Margin="0,0,0,12">
                            <Border x:Name="GpuBar" Background="#22C55E" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <TextBlock Text="🌡" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock x:Name="GpuTemp" Text="--°C" FontSize="13" Foreground="#707070"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RAM Card -->
                <Border Background="#0F0F0F" CornerRadius="16" Padding="24" Margin="6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="44" Height="44" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="💾" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="RAM" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                                <TextBlock Text="MEMORY" FontSize="9" Foreground="#303030"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock x:Name="RamUsage" Text="0%" FontSize="36" Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="RamInfo" Text="0 / 0 GB" FontSize="11" Foreground="#606060"/>
                        </StackPanel>
                        
                        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="4" Height="6" Margin="0,0,0,12">
                            <Border x:Name="RamBar" Background="#8B5CF6" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        
                        <TextBlock Grid.Row="3" Text="System Memory" FontSize="12" Foreground="#505050"/>
                    </Grid>
                </Border>

                <!-- Disk Card -->
                <Border Background="#0F0F0F" CornerRadius="16" Padding="24" Margin="12,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="44" Height="44" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F97316" Offset="0"/>
                                        <GradientStop Color="#EA580C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="💿" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="DISK" FontSize="11" Foreground="#505050" FontWeight="Bold"/>
                                <TextBlock Text="STORAGE" FontSize="9" Foreground="#303030"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock x:Name="DiskUsage" Text="0%" FontSize="36" Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="DiskInfo" Text="0 / 0 GB" FontSize="11" Foreground="#606060"/>
                        </StackPanel>
                        
                        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="4" Height="6" Margin="0,0,0,12">
                            <Border x:Name="DiskBar" Background="#F97316" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        
                        <TextBlock Grid.Row="3" Text="System Drive (C:)" FontSize="12" Foreground="#505050"/>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Quick Actions -->
            <Border Grid.Row="2" Background="#0F0F0F" CornerRadius="16" Padding="28" Margin="0,0,0,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="⚡" FontSize="18" Foreground="#DC2626" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="QUICK ACTIONS" FontSize="12" Foreground="#505050" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <UniformGrid Grid.Row="1" Columns="4">
                        <Border Background="#141414" CornerRadius="12" Padding="20" Margin="0,0,10,0" Cursor="Hand" MouseLeftButtonUp="QuickAction_Cleaner">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#DC262640" Offset="0"/>
                                            <GradientStop Color="#DC262620" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🧹" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Quick Clean" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Remove junk files" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#141414" CornerRadius="12" Padding="20" Margin="5,0" Cursor="Hand" MouseLeftButtonUp="QuickAction_Tweaks">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#22C55E40" Offset="0"/>
                                            <GradientStop Color="#22C55E20" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Optimize" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Apply gaming tweaks" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#141414" CornerRadius="12" Padding="20" Margin="5,0" Cursor="Hand" MouseLeftButtonUp="QuickAction_DNS">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F640" Offset="0"/>
                                            <GradientStop Color="#3B82F620" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🌐" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Fast DNS" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Optimize network" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#141414" CornerRadius="12" Padding="20" Margin="10,0,0,0" Cursor="Hand" MouseLeftButtonUp="QuickAction_Restore">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8B5CF640" Offset="0"/>
                                            <GradientStop Color="#8B5CF620" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="↺" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Restore Point" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Create backup" FontSize="11" Foreground="#606060" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="3" CornerRadius="12" Padding="24,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC262615" Offset="0"/>
                        <GradientStop Color="#0A0A0A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#22C55E" CornerRadius="5" Width="10" Height="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="System Status: " FontSize="13" Foreground="#707070" VerticalAlignment="Center"/>
                        <TextBlock Text="Healthy" FontSize="13" Foreground="#22C55E" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text=" • " FontSize="13" Foreground="#303030" VerticalAlignment="Center"/>
                        <TextBlock x:Name="OptimizationsActive" Text="0 optimizations active" FontSize="13" Foreground="#707070" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="#404040" VerticalAlignment="Center">
                        <Run Text="JGoode's AIO PC Tool"/>
                        <Run Text=" v4.0" Foreground="#DC2626"/>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
