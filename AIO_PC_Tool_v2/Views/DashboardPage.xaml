<Page x:Class="AIO_PC_Tool_v2.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Dashboard"
      Background="Transparent">
    
    <Page.DataContext>
        <vm:DashboardViewModel/>
    </Page.DataContext>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <StackPanel>
            <!-- Header -->
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="System overview and real-time monitoring" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0"/>
            </StackPanel>
            
            <!-- System Info Cards -->
            <TextBlock Text="SYSTEM INFORMATION" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,14" Opacity="0.8"/>
            <UniformGrid Columns="4" Margin="0,0,0,28">
                <!-- CPU Card -->
                <Border Background="{DynamicResource BackgroundCard}" CornerRadius="14" Padding="20" Margin="0,0,12,0" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="#3B82F620" CornerRadius="10" Width="44" Height="44">
                                <TextBlock Text="💻" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="CPU" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SystemInfo.Cpu.Model}" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0">
                            <Run Text="{Binding SystemInfo.Cpu.Cores, Mode=OneWay}"/>
                            <Run Text=" Cores • "/>
                            <Run Text="{Binding SystemInfo.Cpu.Threads, Mode=OneWay}"/>
                            <Run Text=" Threads"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                
                <!-- GPU Card -->
                <Border Background="{DynamicResource BackgroundCard}" CornerRadius="14" Padding="20" Margin="0,0,12,0" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="#A855F720" CornerRadius="10" Width="44" Height="44">
                                <TextBlock Text="🎮" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="GPU" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SystemInfo.Gpu.Model}" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SystemInfo.Gpu.Vram}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- RAM Card -->
                <Border Background="{DynamicResource BackgroundCard}" CornerRadius="14" Padding="20" Margin="0,0,12,0" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="#10B98120" CornerRadius="10" Width="44" Height="44">
                                <TextBlock Text="🧠" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="RAM" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SystemInfo.Memory.Total}" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding SystemInfo.Memory.Type}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Storage Card -->
                <Border Background="{DynamicResource BackgroundCard}" CornerRadius="14" Padding="20" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="#F9731620" CornerRadius="10" Width="44" Height="44">
                                <TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Storage" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SystemInfo.Storage.PrimaryDisk}" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0">
                            <Run Text="{Binding SystemInfo.Storage.FreeSpace, Mode=OneWay}"/>
                            <Run Text=" free"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>
            
            <!-- Live Monitoring -->
            <TextBlock Text="LIVE MONITORING" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,14" Opacity="0.8"/>
            <Border Style="{StaticResource PremiumCard}" Margin="0,0,0,28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                        <Button Content="{Binding IsMonitoring, Converter={StaticResource BoolToStartStopConverter}, FallbackValue='Start Monitoring'}" 
                                Command="{Binding ToggleMonitoringCommand}"
                                Style="{StaticResource PremiumButton}"
                                Padding="20,12"/>
                        <TextBlock Text="Updates every second when active" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextMuted}" 
                                   VerticalAlignment="Center" 
                                   Margin="16,0,0,0"/>
                    </StackPanel>
                    
                    <UniformGrid Grid.Row="1" Columns="4">
                        <!-- CPU Usage -->
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="CPU Usage" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource BackgroundInput}" CornerRadius="4" Height="8">
                                <Border CornerRadius="4" Background="#3B82F6" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource MultiBoolToVisibilityConverter}">
                                            <Binding Path="CpuUsage"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="%" FontSize="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom" Margin="2,0,0,5"/>
                                <TextBlock Text="{Binding CpuTemp, StringFormat={}{0:F0}°C}" FontSize="12" Foreground="#3B82F6" VerticalAlignment="Bottom" Margin="12,0,0,6"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- RAM Usage -->
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="RAM Usage" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource BackgroundInput}" CornerRadius="4" Height="8">
                                <Border CornerRadius="4" Background="#10B981" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource MultiBoolToVisibilityConverter}">
                                            <Binding Path="RamUsage"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="{Binding RamUsage, StringFormat={}{0:F0}}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="%" FontSize="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom" Margin="2,0,0,5"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- GPU Usage -->
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="GPU Usage" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource BackgroundInput}" CornerRadius="4" Height="8">
                                <Border CornerRadius="4" Background="#A855F7" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource MultiBoolToVisibilityConverter}">
                                            <Binding Path="GpuUsage"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="{Binding GpuUsage, StringFormat={}{0:F0}}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="%" FontSize="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom" Margin="2,0,0,5"/>
                                <TextBlock Text="{Binding GpuTemp, StringFormat={}{0:F0}°C}" FontSize="12" Foreground="#A855F7" VerticalAlignment="Bottom" Margin="12,0,0,6"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Tweaks Status -->
                        <StackPanel>
                            <TextBlock Text="Active Tweaks" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10"/>
                            <Border Background="{DynamicResource BackgroundInput}" CornerRadius="4" Height="8">
                                <Border CornerRadius="4" Background="{DynamicResource AccentPrimary}" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource MultiBoolToVisibilityConverter}">
                                            <Binding Path="ActiveTweaks"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="{Binding ActiveTweaks}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource SuccessGreen}"/>
                                <TextBlock Text="{Binding TotalTweaks, StringFormat=/{0}}" FontSize="18" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>
            
            <!-- Quick Actions -->
            <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,14" Opacity="0.8"/>
            <UniformGrid Columns="4">
                <Button Content="🔍 Detect Tweaks" Command="{Binding DetectTweaksCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                <Button Content="🧹 System Cleaner" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                <Button Content="📍 Create Restore Point" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                <Button Content="🌐 Flush DNS" Style="{StaticResource SecondaryButton}"/>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
