<Page x:Class="AIO_PC_Tool_v2.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="#080808" FontFamily="Segoe UI">
    
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <StackPanel>
                <TextBlock FontSize="13" Foreground="#404040" FontWeight="SemiBold" Margin="0,0,0,4">WELCOME BACK</TextBlock>
                <TextBlock FontSize="28" FontWeight="Bold" Foreground="White">
                    <Run Text="System"/>
                    <Run Text=" Overview" Foreground="#E53935"/>
                </TextBlock>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock x:Name="CurrentTime" Text="00:00" FontSize="32" Foreground="White" FontWeight="Light" HorizontalAlignment="Right"/>
                <TextBlock x:Name="CurrentDate" Text="" FontSize="12" Foreground="#505050" HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- Hardware Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU -->
            <Border Grid.Column="0" CornerRadius="16" Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1A1A" Offset="0"/>
                        <GradientStop Color="#141414" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="40" Height="40" CornerRadius="10" Background="#3B82F6">
                            <TextBlock Text="⚙" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="CPU" FontSize="14" Foreground="#808080" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock x:Name="CpuUsage" Text="0%" FontSize="32" Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="CpuName" Text="Loading..." FontSize="11" Foreground="#505050" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Grid Grid.Row="2">
                        <Border Background="#252525" CornerRadius="3" Height="6"/>
                        <Border x:Name="CpuBar" Background="#3B82F6" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- GPU -->
            <Border Grid.Column="2" CornerRadius="16" Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1A1A" Offset="0"/>
                        <GradientStop Color="#141414" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="40" Height="40" CornerRadius="10" Background="#22C55E">
                            <TextBlock Text="🎮" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="GPU" FontSize="14" Foreground="#808080" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock x:Name="GpuUsage" Text="0%" FontSize="32" Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="GpuName" Text="Loading..." FontSize="11" Foreground="#505050" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Grid Grid.Row="2">
                        <Border Background="#252525" CornerRadius="3" Height="6"/>
                        <Border x:Name="GpuBar" Background="#22C55E" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- RAM -->
            <Border Grid.Column="4" CornerRadius="16" Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1A1A" Offset="0"/>
                        <GradientStop Color="#141414" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="40" Height="40" CornerRadius="10" Background="#A855F7">
                            <TextBlock Text="💾" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="RAM" FontSize="14" Foreground="#808080" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock x:Name="RamUsage" Text="0%" FontSize="32" Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="RamInfo" Text="0 / 0 GB" FontSize="11" Foreground="#505050"/>
                    </StackPanel>
                    <Grid Grid.Row="2">
                        <Border Background="#252525" CornerRadius="3" Height="6"/>
                        <Border x:Name="RamBar" Background="#A855F7" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Disk -->
            <Border Grid.Column="6" CornerRadius="16" Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1A1A" Offset="0"/>
                        <GradientStop Color="#141414" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="40" Height="40" CornerRadius="10" Background="#F97316">
                            <TextBlock Text="💿" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DISK" FontSize="14" Foreground="#808080" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock x:Name="DiskUsage" Text="0%" FontSize="32" Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="DiskInfo" Text="0 / 0 GB" FontSize="11" Foreground="#505050"/>
                    </StackPanel>
                    <Grid Grid.Row="2">
                        <Border Background="#252525" CornerRadius="3" Height="6"/>
                        <Border x:Name="DiskBar" Background="#F97316" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Quick Actions -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="14" Padding="20" Cursor="Hand" MouseLeftButtonUp="QuickAction_Cleaner">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#0F0F0F"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#181818"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E53935" Offset="0"/>
                                <GradientStop Color="#C62828" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🧹" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="System Cleaner" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock Text="Remove junk files" FontSize="11" Foreground="#505050" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" CornerRadius="14" Padding="20" Cursor="Hand" MouseLeftButtonUp="QuickAction_Tweaks">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#0F0F0F"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#181818"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#22C55E" Offset="0"/>
                                <GradientStop Color="#16A34A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Optimizations" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock Text="Gaming tweaks" FontSize="11" Foreground="#505050" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" CornerRadius="14" Padding="20" Cursor="Hand" MouseLeftButtonUp="QuickAction_DNS">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#0F0F0F"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#181818"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#2563EB" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="DNS Manager" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock Text="Faster internet" FontSize="11" Foreground="#505050" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" CornerRadius="14" Padding="20" Cursor="Hand" MouseLeftButtonUp="QuickAction_Restore">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#0F0F0F"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#181818"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,0,14" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="#9333EA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="↺" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Restore Points" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock Text="System backup" FontSize="11" Foreground="#505050" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="3" CornerRadius="12" Padding="20,16" VerticalAlignment="Bottom">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E5393520" Offset="0"/>
                    <GradientStop Color="#08080800" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,10,0"/>
                    <TextBlock Text="System Healthy" FontSize="13" Foreground="#707070"/>
                    <TextBlock Text=" • " FontSize="13" Foreground="#303030"/>
                    <TextBlock x:Name="OptimizationsActive" Text="0 optimizations" FontSize="13" Foreground="#707070"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="#404040">
                    <Run Text="JGoode's AIO"/>
                    <Run Text=" v4.0" Foreground="#E53935"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Page>
