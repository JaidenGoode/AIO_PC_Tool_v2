<Page x:Class="AIO_PC_Tool_v2.Views.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tweaks" Background="#080808" FontFamily="Segoe UI">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Padding="32,24,32,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock FontSize="13" Foreground="#404040" FontWeight="SemiBold" Margin="0,0,0,4">PERFORMANCE</TextBlock>
                        <TextBlock FontSize="28" FontWeight="Bold">
                            <Run Text="System" Foreground="White"/>
                            <Run Text=" Optimizations" Foreground="#E53935"/>
                        </TextBlock>
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" CornerRadius="10" Padding="16,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#22C55E20" Offset="0"/>
                                <GradientStop Color="#22C55E10" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ActiveCount" Text="0" FontSize="20" Foreground="#22C55E" FontWeight="Bold"/>
                            <TextBlock x:Name="TotalCount" Text=" / 35 active" FontSize="14" Foreground="#505050" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Filter Bar -->
                <Border Grid.Row="1" CornerRadius="12" Padding="16,12" Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#121212" Offset="0"/>
                            <GradientStop Color="#0F0F0F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="FILTER" FontSize="10" Foreground="#353535" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Border Background="#0A0A0A" CornerRadius="6" Padding="3">
                                <StackPanel x:Name="CategoryButtons" Orientation="Horizontal"/>
                            </Border>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button x:Name="ApplyAllBtn" Click="ApplyAll_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="20,9">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" Margin="0,0,6,0"/>
                                    <TextBlock Text="Apply All"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RevertAllBtn" Click="RevertAll_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Padding="20,9">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↺" Margin="0,0,6,0"/>
                                    <TextBlock Text="Revert All"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Tweaks List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,0,32,24">
            <StackPanel x:Name="TweaksList"/>
        </ScrollViewer>
    </Grid>
</Page>
