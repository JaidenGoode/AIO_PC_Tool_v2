<Page x:Class="AIO_PC_Tool_v2.Views.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tweaks" Background="#0A0A0A">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#0A0A0A" Padding="40,30,40,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title Row -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock FontSize="28" FontWeight="Bold">
                            <Run Text="System" Foreground="White"/>
                            <Run Text="Tweaks" Foreground="#DC2626"/>
                        </TextBlock>
                        <TextBlock Text="Safe, reversible Windows optimizations for gaming, performance and privacy" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#14141" CornerRadius="8" Padding="20,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" Foreground="#22C55E" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ActiveCount" Text="0" FontSize="20" Foreground="#22C55E" FontWeight="Bold"/>
                                        <TextBlock x:Name="TotalCount" Text=" / 30" FontSize="20" Foreground="#505050" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock Text="optimizations active" FontSize="10" Foreground="#606060"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                
                <!-- Controls Bar -->
                <Border Grid.Row="1" Background="#141414" CornerRadius="10" Padding="16" Margin="0,0,0,20">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="FILTER" FontSize="10" Foreground="#505050" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Border Background="#0A0A0A" CornerRadius="6" Padding="4">
                                <StackPanel x:Name="CategoryButtons" Orientation="Horizontal"/>
                            </Border>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="ApplyAllBtn" Content="Apply All in Category" Click="ApplyAll_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="20,10"/>
                            <Button x:Name="RevertAllBtn" Content="Revert All in Category" Click="RevertAll_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Padding="20,10"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Tweaks List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40,0,40,30">
            <StackPanel x:Name="TweaksList"/>
        </ScrollViewer>
    </Grid>
</Page>
