<Page x:Class="AIO_PC_Tool_v2.Views.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tweaks" Background="#0A0A0A" FontFamily="Segoe UI">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#0A0A0A" Padding="40,30,40,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title Row -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock FontSize="32" FontWeight="Bold">
                            <Run Text="System" Foreground="White"/>
                            <Run Text=" Optimizations" Foreground="#DC2626"/>
                        </TextBlock>
                        <TextBlock Text="Safe, reversible Windows optimizations • Gaming • Performance • Privacy" FontSize="14" Foreground="#606060" Margin="0,8,0,0"/>
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="12" Padding="24,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#22C55E20" Offset="0"/>
                                <GradientStop Color="#22C55E10" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#22C55E" CornerRadius="6" Width="12" Height="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ActiveCount" Text="0" FontSize="28" Foreground="#22C55E" FontWeight="Bold"/>
                                    <TextBlock x:Name="TotalCount" Text=" / 35" FontSize="28" Foreground="#404040" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="optimizations active" FontSize="11" Foreground="#505050"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Controls Bar -->
                <Border Grid.Row="1" Background="#0F0F0F" CornerRadius="12" Padding="20,14" Margin="0,0,0,20">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="CATEGORY" FontSize="10" Foreground="#404040" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <Border Background="#141414" CornerRadius="8" Padding="4">
                                <StackPanel x:Name="CategoryButtons" Orientation="Horizontal"/>
                            </Border>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="ApplyAllBtn" Click="ApplyAll_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="24,11">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="12" Margin="0,0,8,0"/>
                                    <TextBlock Text="Apply All in Category" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RevertAllBtn" Click="RevertAll_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Padding="24,11">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↺" FontSize="12" Margin="0,0,8,0"/>
                                    <TextBlock Text="Revert All" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Tweaks List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40,0,40,30">
            <StackPanel x:Name="TweaksList"/>
        </ScrollViewer>
    </Grid>
</Page>
