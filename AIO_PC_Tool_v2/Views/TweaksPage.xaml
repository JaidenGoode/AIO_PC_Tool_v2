<Page x:Class="AIO_PC_Tool_v2.Views.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tweaks" Background="#0A0A0A">
    
    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock FontSize="28" FontWeight="Bold">
                    <Run Text="System" Foreground="White"/>
                    <Run Text="Tweaks" Foreground="#DC2626"/>
                </TextBlock>
                <TextBlock Text="Safe, reversible optimizations for gaming, performance &amp; privacy" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Border Background="#14141" CornerRadius="8" Padding="16,10" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" Foreground="#22C55E" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ActiveCount" Text="0" FontSize="14" Foreground="#22C55E" FontWeight="Bold"/>
                        <TextBlock Text=" active" FontSize="14" Foreground="#606060"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
        
        <!-- Controls -->
        <Border Grid.Row="1" Background="#141414" CornerRadius="10" Padding="16" Margin="0,0,0,20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CATEGORY" FontSize="10" Foreground="#505050" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Border Background="#0A0A0A" CornerRadius="6" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="CatAll" Content="All" Click="Category_Click" Tag="All" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatGaming" Content="Gaming" Click="Category_Click" Tag="Gaming" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatPerformance" Content="Performance" Click="Category_Click" Tag="Performance" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatPrivacy" Content="Privacy" Click="Category_Click" Tag="Privacy" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatNetwork" Content="Network" Click="Category_Click" Tag="Network" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatVisual" Content="Visual" Click="Category_Click" Tag="Visual" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatPower" Content="Power" Click="Category_Click" Tag="Power" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatSecurity" Content="Security" Click="Category_Click" Tag="Security" Style="{StaticResource CategoryButtonStyle}"/>
                            <Button x:Name="CatStorage" Content="Storage" Click="Category_Click" Tag="Storage" Style="{StaticResource CategoryButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="Apply All" Click="ApplyAll_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="20,10"/>
                    <Button Content="Revert All" Click="RevertAll_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Padding="20,10"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Tweaks List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="TweaksList"/>
        </ScrollViewer>
    </Grid>
</Page>
