<Page x:Class="AIO_PC_Tool_v2.Views.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Tweaks"
      Background="Transparent">
    
    <Page.DataContext>
        <vm:TweaksViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="System Tweaks" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0">
                    <Run Text="{Binding OptimizedCount, Mode=OneWay}"/>
                    <Run Text=" of "/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text=" optimizations active"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Quick Stats Card -->
            <Border Grid.Column="1" Style="{StaticResource SmallCard}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding OptimizedCount}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessGreen}" VerticalAlignment="Center"/>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="OPTIMIZED" FontSize="10" Foreground="{DynamicResource SuccessGreen}" FontWeight="Bold"/>
                        <TextBlock Text="tweaks active" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Filters & Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <!-- Search -->
                <Border Background="{DynamicResource BackgroundInput}" CornerRadius="10" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="14" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                        <TextBox Width="240" 
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimary}"
                                 CaretBrush="{DynamicResource AccentPrimary}"
                                 VerticalAlignment="Center"
                                 Padding="0,10"/>
                    </StackPanel>
                </Border>
                
                <!-- Category Filter -->
                <ComboBox ItemsSource="{Binding Categories}" 
                          SelectedItem="{Binding SelectedCategory}"
                          Width="140"
                          Margin="12,0,0,0"
                          Padding="12,10"
                          Background="{DynamicResource BackgroundInput}"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource BorderSubtle}"/>
                
                <!-- Refresh Button -->
                <Button Content="↻ Refresh" 
                        Command="{Binding DetectAllCommand}" 
                        Style="{StaticResource SecondaryButton}" 
                        Margin="12,0,0,0"
                        Padding="16,10"
                        IsEnabled="{Binding IsDetecting, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>
            
            <!-- Presets -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="PRESETS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Command="{Binding ApplyPresetCommand}" CommandParameter="gaming" Padding="14,8" Margin="0,0,8,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#A855F7"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <TextBlock Text="🎮 Gaming" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding ApplyPresetCommand}" CommandParameter="privacy" Padding="14,8" Margin="0,0,8,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#10B981"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <TextBlock Text="🔒 Privacy" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding ApplyPresetCommand}" CommandParameter="performance" Padding="14,8" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3B82F6"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <TextBlock Text="⚡ Performance" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
        
        <!-- Tweaks List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <ItemsControl ItemsSource="{Binding FilteredTweaks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource BackgroundCard}" 
                                CornerRadius="12" 
                                Padding="20" 
                                Margin="0,0,0,10"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessGreen}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderActive}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <!-- Title Row with Badges -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                        
                                        <!-- Category Badge -->
                                        <Border CornerRadius="6" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                                                Background="{Binding Category, Converter={StaticResource CategoryToColorConverter}}">
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                        
                                        <!-- Status Badge -->
                                        <Border CornerRadius="6" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Background="{Binding IsActive, Converter={StaticResource BoolToStatusColorConverter}}">
                                            <TextBlock FontSize="10" FontWeight="Bold"
                                                       Text="{Binding IsActive, Converter={StaticResource BoolToOptimizedConverter}}"
                                                       Foreground="{Binding IsActive, Converter={StaticResource BoolToStatusTextColorConverter}}"/>
                                        </Border>
                                    </StackPanel>
                                    
                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}" 
                                               FontSize="13" 
                                               Foreground="{DynamicResource TextSecondary}" 
                                               TextWrapping="Wrap" 
                                               MaxWidth="600" 
                                               Margin="0,0,0,8"/>
                                    
                                    <!-- Warning (if present) -->
                                    <Border Visibility="{Binding Warning, Converter={StaticResource NullToVisibilityConverter}}" 
                                            Background="{DynamicResource WarningOrangeLight}" 
                                            CornerRadius="8" 
                                            Padding="10,6" 
                                            Margin="0,4,0,0" 
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚠" FontSize="12" Foreground="{DynamicResource WarningOrange}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Warning}" FontSize="11" Foreground="{DynamicResource WarningOrange}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Action Area -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Action Button -->
                                    <Button Command="{Binding ToggleCommand}"
                                            MinWidth="100"
                                            Padding="16,10"
                                            Margin="20,0,0,0"
                                            IsEnabled="{Binding IsApplying, Converter={StaticResource InverseBoolConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" 
                                                                    Background="{TemplateBinding Background}" 
                                                                    CornerRadius="8" 
                                                                    Padding="{TemplateBinding Padding}">
                                                                <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToOptimizeRevertConverter}}" 
                                                                           FontSize="12" 
                                                                           FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BackgroundCardHover}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <!-- Toggle Switch -->
                                    <ToggleButton IsChecked="{Binding IsActive, Mode=OneWay}"
                                                  Command="{Binding ToggleCommand}"
                                                  Style="{StaticResource PremiumToggle}"
                                                  Margin="16,0,0,0"
                                                  IsEnabled="{Binding IsApplying, Converter={StaticResource InverseBoolConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource BackgroundCard}" CornerRadius="10" Padding="16,12" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="ℹ" FontSize="14" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Loading Indicator -->
                <Border Grid.Column="1" Width="20" Height="20" CornerRadius="10" Background="{DynamicResource AccentPrimary}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsApplying}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDetecting}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="..." FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
