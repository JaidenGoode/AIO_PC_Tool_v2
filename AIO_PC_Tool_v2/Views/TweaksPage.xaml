<Page x:Class="AIO_PC_Tool_v2.Views.TweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      xmlns:helpers="clr-namespace:AIO_PC_Tool_v2.Helpers"
      Title="Tweaks" Background="Transparent">
    
    <Page.DataContext>
        <vm:TweaksViewModel/>
    </Page.DataContext>
    
    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:BoolToOptimizedConverter x:Key="BoolToOptimizedConverter"/>
        <helpers:BoolToStatusColorConverter x:Key="BoolToStatusColorConverter"/>
        <helpers:BoolToStatusTextColorConverter x:Key="BoolToStatusTextColorConverter"/>
        <helpers:CategoryToColorConverter x:Key="CategoryToColorConverter"/>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Page.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="System Tweaks" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Optimize your Windows system with safe, reversible tweaks" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Filters and Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Search -->
            <TextBox Grid.Column="0" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Search tweaks..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,16,0"/>
            
            <!-- Category Filter -->
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      Width="150" Margin="0,0,16,0"/>
            
            <!-- Bulk Actions -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Apply All" Command="{Binding ApplyAllCommand}"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Background="{DynamicResource AccentPrimary}" Foreground="White"
                        Margin="0,0,8,0"/>
                <Button Content="Revert All" Command="{Binding RevertAllCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </StackPanel>
        </Grid>
        
        <!-- Tweaks List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredTweaks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource BackgroundCard}" CornerRadius="10" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <!-- Title Row with Badges -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                        
                                        <!-- Category Badge -->
                                        <Border CornerRadius="6" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                                                Background="{Binding Category, Converter={StaticResource CategoryToColorConverter}}">
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                        
                                        <!-- Status Badge -->
                                        <Border CornerRadius="6" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Background="{Binding IsActive, Converter={StaticResource BoolToStatusColorConverter}}">
                                            <TextBlock FontSize="10" FontWeight="Bold"
                                                       Text="{Binding IsActive, Converter={StaticResource BoolToOptimizedConverter}}"
                                                       Foreground="{Binding IsActive, Converter={StaticResource BoolToStatusTextColorConverter}}"/>
                                        </Border>
                                        
                                        <!-- Windows Version Badge -->
                                        <Border CornerRadius="6" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Background="{DynamicResource BackgroundCardHover}">
                                            <TextBlock Text="{Binding WindowsVersion, StringFormat=Win {0}}" FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="Medium"/>
                                        </Border>
                                    </StackPanel>
                                    
                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}" 
                                               FontSize="13" 
                                               Foreground="{DynamicResource TextSecondary}" 
                                               TextWrapping="Wrap" 
                                               MaxWidth="600" 
                                               Margin="0,0,0,8"/>
                                    
                                    <!-- Warning (if present) -->
                                    <Border Visibility="{Binding Warning, Converter={StaticResource NullToVisibilityConverter}}" 
                                            Background="#FEF3C7" 
                                            CornerRadius="8" 
                                            Padding="12,8" 
                                            Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AlertCircle" Foreground="#D97706" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Warning}" FontSize="12" Foreground="#92400E" Margin="8,0,0,0" TextWrapping="Wrap" MaxWidth="550"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Action Buttons -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Apply" 
                                            Command="{Binding DataContext.ApplyTweakCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                            Background="{DynamicResource AccentPrimary}" Foreground="White"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                            Margin="0,0,8,0" Padding="16,8"/>
                                    <Button Content="Revert" 
                                            Command="{Binding DataContext.RevertTweakCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Padding="16,8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
