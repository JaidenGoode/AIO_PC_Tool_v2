<Page x:Class="AIO_PC_Tool_v2.Views.RestorePointsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Restore Points" Background="Transparent">
    
    <Page.DataContext>
        <vm:RestorePointsViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Restore Points" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Create and manage Windows System Restore points" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Create New -->
        <Border Grid.Row="1" Background="{StaticResource BackgroundCard}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox Grid.Column="0" 
                         Text="{Binding NewPointName, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Enter restore point name..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,16,0"/>
                
                <Button Grid.Column="1" Content="Create Restore Point" 
                        Command="{Binding CreateRestorePointCommand}"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Background="{StaticResource AccentPrimary}" Foreground="White"
                        Padding="20,12"/>
            </Grid>
        </Border>
        
        <!-- Existing Restore Points -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="EXISTING RESTORE POINTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <Button Content="Refresh" Command="{Binding LoadRestorePointsCommand}" 
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="{StaticResource TextSecondary}" Margin="16,0,0,0"/>
            </StackPanel>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RestorePoints}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundCard}" CornerRadius="10" Padding="16" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Background="{StaticResource SuccessGreen}" CornerRadius="8" Padding="10" Opacity="0.2" VerticalAlignment="Center"/>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="Restore" Width="20" Height="20" Foreground="{StaticResource SuccessGreen}" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding CreationTime, StringFormat={}{0:MMMM dd, yyyy 'at' HH:mm}}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding SequenceNumber, StringFormat='#{0}'}" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
