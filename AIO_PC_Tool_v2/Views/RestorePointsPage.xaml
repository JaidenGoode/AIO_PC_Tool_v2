<Page x:Class="AIO_PC_Tool_v2.Views.RestorePointsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Restore Points" Background="#0A0A0A">
    
    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="28" FontWeight="Bold">
                <Run Text="System" Foreground="White"/>
                <Run Text="Restore" Foreground="#DC2626"/>
            </TextBlock>
            <TextBlock Text="Create and manage Windows System Restore points for safe recovery" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Info Banner -->
        <Border Grid.Row="1" Background="#141414" CornerRadius="10" Padding="20,16" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ" FontSize="16" Foreground="#3B82F6" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Create a restore point before making system changes. You can restore your PC to a previous state if something goes wrong." FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <!-- Create New Section -->
        <Border Grid.Row="2" Background="#141414" CornerRadius="10" Padding="20" Margin="0,0,0,24">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="➕" FontSize="14" Foreground="#22C55E" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="CREATE NEW RESTORE POINT" FontSize="11" Foreground="#505050" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="6" Margin="0,0,16,0">
                        <TextBox x:Name="PointName" 
                                 Background="Transparent" 
                                 Foreground="White" 
                                 BorderThickness="0" 
                                 Padding="16,12" 
                                 FontSize="14"
                                 VerticalContentAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="Placeholder" 
                                                               Text="Enter a descriptive name (e.g., 'Before driver update')" 
                                                               Foreground="#505050" 
                                                               VerticalAlignment="Center"
                                                               Margin="16,0,0,0"
                                                               IsHitTestVisible="False"
                                                               Visibility="Collapsed"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>
                    <Button Grid.Column="1" Click="Create_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="24,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Create Point" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
        
        <!-- Existing Points -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="↺" FontSize="14" Foreground="#DC2626" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="EXISTING RESTORE POINTS" FontSize="11" FontWeight="Bold" Foreground="#505050" VerticalAlignment="Center"/>
                <Button Content="Refresh" Click="Refresh_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="16,0,0,0" Padding="16,8"/>
            </StackPanel>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PointsList"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
