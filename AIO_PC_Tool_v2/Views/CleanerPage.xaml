<Page x:Class="AIO_PC_Tool_v2.Views.CleanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Cleaner" Background="#0A0A0A">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#0A0A0A" Padding="40,30,40,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock FontSize="28" FontWeight="Bold">
                            <Run Text="PC" Foreground="White"/>
                            <Run Text="Cleaner" Foreground="#DC2626"/>
                        </TextBlock>
                        <TextBlock Text="Advanced system cleaning • DirectX shaders • Browser cache • Gaming platforms" FontSize="13" Foreground="#606060" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="POTENTIAL SAVINGS" FontSize="10" Foreground="#505050" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="TotalSize" Text="Scan to detect" FontSize="22" Foreground="#DC2626" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
                
                <!-- Stats Bar -->
                <Border Grid.Row="1" Background="#141414" CornerRadius="10" Padding="20,16" Margin="0,0,0,20">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <!-- Files Found -->
                            <Border Background="#1A1A1A" CornerRadius="6" Padding="16,10" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock x:Name="TotalFiles" Text="0" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                        <TextBlock Text="files found" FontSize="10" Foreground="#606060"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Categories Selected -->
                            <Border Background="#1A1A1A" CornerRadius="6" Padding="16,10" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock x:Name="CategoriesSelected" Text="0 / 0" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                        <TextBlock Text="categories selected" FontSize="10" Foreground="#606060"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Last Clean -->
                            <Border Background="#1A1A1A" CornerRadius="6" Padding="16,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🕐" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock x:Name="LastCleanTime" Text="Never" FontSize="16" Foreground="White" FontWeight="Bold"/>
                                        <TextBlock Text="last cleaned" FontSize="10" Foreground="#606060"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Action Buttons -->
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="SelectAllBtn" Content="Select All" Click="SelectAll_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="16,10" Margin="0,0,10,0"/>
                            <Button x:Name="DeselectAllBtn" Content="Deselect All" Click="DeselectAll_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="16,10" Margin="0,0,10,0"/>
                            <Button x:Name="ScanButton" Click="Scan_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="24,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ScanIcon" Text="🔍" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ScanText" Text="Scan System"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CleanButton" Click="Clean_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="24,10" Margin="10,0,0,0" IsEnabled="False">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧹" Margin="0,0,8,0"/>
                                    <TextBlock Text="Clean Now"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Categories Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40,0,40,30">
            <StackPanel x:Name="CategoriesContainer"/>
        </ScrollViewer>
    </Grid>
</Page>
