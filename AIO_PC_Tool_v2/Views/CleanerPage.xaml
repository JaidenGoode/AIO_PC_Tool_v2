<Page x:Class="AIO_PC_Tool_v2.Views.CleanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Cleaner" Background="#080808" FontFamily="Segoe UI">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Padding="32,24,32,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock FontSize="13" Foreground="#404040" FontWeight="SemiBold" Margin="0,0,0,4">MAINTENANCE</TextBlock>
                        <TextBlock FontSize="28" FontWeight="Bold">
                            <Run Text="System" Foreground="White"/>
                            <Run Text=" Cleaner" Foreground="#E53935"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <TextBlock Text="SPACE TO FREE" FontSize="10" Foreground="#353535" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalSize" Text="—" FontSize="28" Foreground="#E53935" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
                
                <!-- Action Bar -->
                <Border Grid.Row="1" CornerRadius="12" Padding="20,14" Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#121212" Offset="0"/>
                            <GradientStop Color="#0F0F0F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#0A0A0A" CornerRadius="8" Padding="16,10" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TotalFiles" Text="—" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text=" files" FontSize="14" Foreground="#505050"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0A0A0A" CornerRadius="8" Padding="16,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="CategoriesCount" Text="—" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text=" categories" FontSize="14" Foreground="#505050"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button x:Name="SelectAllBtn" Content="Select All" Click="SelectAll_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="18,10" Margin="0,0,8,0"/>
                            <Button x:Name="ScanButton" Click="Scan_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="24,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ScanIcon" Text="🔍" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ScanText" Text="Scan Now"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CleanButton" Click="Clean_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="24,10" Margin="8,0,0,0" IsEnabled="False">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧹" Margin="0,0,8,0"/>
                                    <TextBlock Text="Clean"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Initial -->
            <Border x:Name="InitialState" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,60">
                    <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1A1A" Offset="0"/>
                                <GradientStop Color="#141414" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🔍" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Ready to Scan" FontSize="24" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click 'Scan Now' to find junk files" FontSize="13" Foreground="#505050" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Scanning -->
            <Border x:Name="ScanningState" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,60">
                    <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1A1A" Offset="0"/>
                                <GradientStop Color="#141414" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock x:Name="ScanningIcon" Text="⏳" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Scanning..." FontSize="24" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ScanningStatus" Text="Finding junk files..." FontSize="13" Foreground="#505050" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- All Clean -->
            <Border x:Name="AllCleanState" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,60">
                    <Border Width="90" Height="90" CornerRadius="45" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#22C55E" Offset="0"/>
                                <GradientStop Color="#16A34A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="✓" FontSize="40" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="All Clean!" FontSize="26" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="No junk files found on your system" FontSize="13" Foreground="#606060" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Results -->
            <ScrollViewer x:Name="ResultsState" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="32,0,32,24">
                <StackPanel x:Name="CategoriesContainer"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
