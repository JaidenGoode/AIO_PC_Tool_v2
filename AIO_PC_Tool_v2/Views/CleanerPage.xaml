<Page x:Class="AIO_PC_Tool_v2.Views.CleanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Cleaner" Background="#0A0A0A">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#0A0A0A" Padding="40,30,40,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Title -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock FontSize="32" FontWeight="Bold" FontFamily="Segoe UI">
                            <Run Text="System" Foreground="White"/>
                            <Run Text=" Cleaner" Foreground="#DC2626"/>
                        </TextBlock>
                        <TextBlock Text="Deep clean your PC • Remove junk files • Free up disk space instantly" FontSize="14" Foreground="#606060" Margin="0,6,0,0" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="SPACE TO FREE" FontSize="10" Foreground="#404040" HorizontalAlignment="Right" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TotalSize" Text="—" FontSize="28" Foreground="#DC2626" FontWeight="Bold" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
                
                <!-- Stats Bar -->
                <Border Grid.Row="1" Background="Linear" CornerRadius="12" Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#141414" Offset="0"/>
                            <GradientStop Color="#1A1A1A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="24,18">
                        <StackPanel Orientation="Horizontal">
                            <!-- Files Found -->
                            <Border Background="#0F0F0F" CornerRadius="10" Padding="20,14" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#DC262620" CornerRadius="8" Width="40" Height="40" Margin="0,0,14,0">
                                        <TextBlock Text="📁" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="TotalFiles" Text="—" FontSize="20" Foreground="White" FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock Text="files found" FontSize="11" Foreground="#505050" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Categories -->
                            <Border Background="#0F0F0F" CornerRadius="10" Padding="20,14" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#3B82F620" CornerRadius="8" Width="40" Height="40" Margin="0,0,14,0">
                                        <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="CategoriesCount" Text="—" FontSize="20" Foreground="White" FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock Text="categories" FontSize="11" Foreground="#505050" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Last Clean -->
                            <Border Background="#0F0F0F" CornerRadius="10" Padding="20,14">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#22C55E20" CornerRadius="8" Width="40" Height="40" Margin="0,0,14,0">
                                        <TextBlock Text="✓" FontSize="18" Foreground="#22C55E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="LastCleanTime" Text="Never" FontSize="20" Foreground="White" FontWeight="Bold" FontFamily="Segoe UI"/>
                                        <TextBlock Text="last cleaned" FontSize="11" Foreground="#505050" FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Action Buttons -->
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="SelectAllBtn" Content="Select All" Click="SelectAll_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="20,12" Margin="0,0,10,0" FontFamily="Segoe UI"/>
                            <Button x:Name="ScanButton" Click="Scan_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="28,12" FontFamily="Segoe UI">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ScanIcon" Text="🔍" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="ScanText" Text="Scan Now" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CleanButton" Click="Clean_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="28,12" Margin="10,0,0,0" IsEnabled="False" FontFamily="Segoe UI">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧹" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Clean Selected" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <!-- Initial State -->
            <Border x:Name="InitialState" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,80">
                    <Border Background="#141414" CornerRadius="50" Width="100" Height="100" Margin="0,0,0,30">
                        <TextBlock Text="🔍" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Ready to Scan" FontSize="28" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Text="Click 'Scan Now' to detect junk files on your system" FontSize="14" Foreground="#606060" HorizontalAlignment="Center" Margin="0,10,0,30" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                            <TextBlock Text="✓ Safe cleaning only" FontSize="12" Foreground="#22C55E" FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16,10" Margin="0,0,8,0">
                            <TextBlock Text="✓ No personal files" FontSize="12" Foreground="#22C55E" FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16,10">
                            <TextBlock Text="✓ Shows only what you have" FontSize="12" Foreground="#22C55E" FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Scanning State -->
            <Border x:Name="ScanningState" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,80">
                    <Border Background="#141414" CornerRadius="50" Width="100" Height="100" Margin="0,0,0,30">
                        <TextBlock x:Name="ScanningIcon" Text="⏳" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Scanning Your System..." FontSize="28" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="ScanningStatus" Text="Finding junk files and cache..." FontSize="14" Foreground="#606060" HorizontalAlignment="Center" Margin="0,10,0,0" FontFamily="Segoe UI"/>
                    <Border Background="#1A1A1A" CornerRadius="4" Width="300" Height="4" Margin="0,30,0,0">
                        <Border x:Name="ScanProgress" Background="#DC2626" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- All Clean State -->
            <Border x:Name="AllCleanState" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,80">
                    <Border CornerRadius="60" Width="120" Height="120" Margin="0,0,0,30">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#22C55E" Offset="0"/>
                                <GradientStop Color="#16A34A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="✓" FontSize="56" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="You're All Clean!" FontSize="32" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Text="No junk files or cache found on your system" FontSize="15" Foreground="#808080" HorizontalAlignment="Center" Margin="0,12,0,30" FontFamily="Segoe UI"/>
                    <Border Background="#22C55E15" CornerRadius="12" Padding="24,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💚" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Your PC is running at optimal performance" FontSize="13" Foreground="#22C55E" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Results with Categories -->
            <ScrollViewer x:Name="ResultsState" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="40,0,40,30">
                <StackPanel x:Name="CategoriesContainer"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
