<Page x:Class="AIO_PC_Tool_v2.Views.CleanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:AIO_PC_Tool_v2.ViewModels"
      Title="Cleaner" Background="Transparent">
    
    <Page.DataContext>
        <vm:CleanerViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="System Cleaner" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Remove temporary files, caches, and junk to free up disk space" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            
            <!-- Categories List -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,24,0">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundCard}" CornerRadius="10" Padding="16" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding FileCount, StringFormat={}{0} files}" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding SizeHuman}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource AccentSecondary}" VerticalAlignment="Center" MinWidth="80" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Summary Panel -->
            <Border Grid.Column="1" Background="{StaticResource BackgroundCard}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="SUMMARY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,16"/>
                    
                    <Border Background="{StaticResource BackgroundCardHover}" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalSize}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentPrimary}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total to clean" FontSize="12" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="{Binding TotalFiles, StringFormat={}{0} files found}" FontSize="13" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <Button Content="Scan System" Command="{Binding ScanCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                    <Button Content="Select All" Command="{Binding SelectAllCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                    <Button Content="Clean Selected" Command="{Binding CleanCommand}" 
                            Style="{StaticResource MaterialDesignFlatMidBgButton}" 
                            Background="{StaticResource AccentPrimary}" Foreground="White"
                            HorizontalAlignment="Stretch"/>
                    
                    <!-- History -->
                    <TextBlock Text="CLEANING HISTORY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,24,0,12"/>
                    <ItemsControl ItemsSource="{Binding History}" MaxHeight="150">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundCardHover}" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:MMM dd, HH:mm}}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FreedHuman}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SuccessGreen}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundCard}" CornerRadius="8" Padding="12" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Information" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
