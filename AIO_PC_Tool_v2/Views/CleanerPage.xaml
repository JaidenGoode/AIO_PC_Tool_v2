<Page x:Class="AIO_PC_Tool_v2.Views.CleanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Cleaner" Background="#0D0D0D">
    
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="System Cleaner" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Remove temporary files, caches, and junk to free up disk space" FontSize="14" Foreground="#A3A3A3" Margin="0,4,0,0"/>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            
            <!-- Categories -->
            <ScrollViewer Grid.Column="0" Margin="0,0,24,0">
                <StackPanel x:Name="CategoriesList"/>
            </ScrollViewer>
            
            <!-- Summary -->
            <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="SUMMARY" FontSize="11" FontWeight="Bold" Foreground="#737373" Margin="0,0,0,16"/>
                    
                    <Border Background="#252525" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TotalSize" Text="0 B" FontSize="32" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total to clean" FontSize="12" Foreground="#A3A3A3" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="Scan System" Click="Scan_Click" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                    <Button Content="Clean Selected" Click="Clean_Click" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Status -->
        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="8" Padding="12" Margin="0,16,0,0">
            <TextBlock x:Name="StatusText" Text="Ready to scan" FontSize="13" Foreground="#A3A3A3"/>
        </Border>
    </Grid>
</Page>
