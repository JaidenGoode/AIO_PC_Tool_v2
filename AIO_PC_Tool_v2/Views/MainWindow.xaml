<Window x:Class="AIO_PC_Tool_v2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:AIO_PC_Tool_v2.Views"
        Title="JGoode's AIO PC Tool v2" 
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundMain}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource BackgroundCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo/Header -->
                <StackPanel Grid.Row="0" Margin="20,24,20,32">
                    <TextBlock Text="JGoode's" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Text="AIO PC Tool" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}"/>
                    <TextBlock Text="v4.0" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button x:Name="NavDashboard" Content="Dashboard" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Dashboard">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dashboard" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="NavTweaks" Content="Tweaks" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Tweaks">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Tune" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tweaks" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="NavCleaner" Content="Cleaner" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Cleaner">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Broom" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Cleaner" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="NavDns" Content="DNS Manager" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Dns">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Dns" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="DNS Manager" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="NavRestore" Content="Restore Points" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Restore">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Restore" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Restore Points" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="NavUtilities" Content="Utilities" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Utilities">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Toolbox" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="Utilities" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>

                <!-- Settings Button -->
                <Button Grid.Row="2" x:Name="NavSettings" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="Settings" Margin="12,0,12,20">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="Settings" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Margin="32,24"/>
    </Grid>
</Window>
