<Window x:Class="AIO_PC_Tool_v2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JGoode's AIO PC Tool v2" 
        Height="900" Width="1500"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#1F1F1F" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#0C0C0C">
                <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                    <Border Width="14" Height="14" CornerRadius="7" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#DC2626" Offset="0"/>
                                <GradientStop Color="#EF4444" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="JGOODE" FontSize="11" Foreground="#DC2626" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="AIO PC TOOL" FontSize="11" Foreground="#606060" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#DC262620" CornerRadius="4" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v4.0" FontSize="9" Foreground="#DC2626" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="─" Click="Minimize_Click" Style="{StaticResource WindowButtonStyle}" Width="50" Height="44" FontSize="12"/>
                    <Button Content="□" Click="Maximize_Click" Style="{StaticResource WindowButtonStyle}" Width="50" Height="44" FontSize="12"/>
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource CloseButtonStyle}" Width="50" Height="44" FontSize="12"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="#0C0C0C" BorderBrush="#151515" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo Section -->
                        <StackPanel Grid.Row="0" Margin="24,28,24,32">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="44" Height="44" CornerRadius="12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#DC2626" Offset="0"/>
                                            <GradientStop Color="#B91C1C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="16" FontWeight="Bold">
                                        <Run Text="JGoode" Foreground="White"/>
                                        <Run Text="'s" Foreground="#DC2626"/>
                                    </TextBlock>
                                    <TextBlock Text="PC OPTIMIZER" FontSize="10" Foreground="#505050" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="#DC262615" CornerRadius="6" Padding="10,6" Margin="0,16,0,0" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#22C55E" Margin="0,0,8,0"/>
                                    <TextBlock Text="ADMINISTRATOR" FontSize="9" Foreground="#DC2626" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Navigation -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0">
                                <TextBlock Text="MAIN" FontSize="10" Foreground="#404040" FontWeight="Bold" Margin="12,0,0,10"/>
                                <Button x:Name="NavDashboard" Click="NavButton_Click" Tag="Dashboard" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Dashboard" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavCleaner" Click="NavButton_Click" Tag="Cleaner" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧹" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="System Cleaner" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavTweaks" Click="NavButton_Click" Tag="Tweaks" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Optimizations" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavUtilities" Click="NavButton_Click" Tag="Utilities" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔧" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Utilities" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                
                                <TextBlock Text="NETWORK" FontSize="10" Foreground="#404040" FontWeight="Bold" Margin="12,24,0,10"/>
                                <Button x:Name="NavDns" Click="NavButton_Click" Tag="Dns" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌐" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="DNS Manager" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                
                                <TextBlock Text="SYSTEM" FontSize="10" Foreground="#404040" FontWeight="Bold" Margin="12,24,0,10"/>
                                <Button x:Name="NavRestore" Click="NavButton_Click" Tag="Restore" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="↺" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Restore Points" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavSettings" Click="NavButton_Click" Tag="Settings" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙" FontSize="15" Margin="0,0,12,0"/>
                                        <TextBlock Text="Settings" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <StackPanel Grid.Row="2" Margin="16,0,16,20">
                            <Border CornerRadius="10" Padding="16" Cursor="Hand">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A1A1A" Offset="0"/>
                                        <GradientStop Color="#141414" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="💬" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Join Discord" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="Community &amp; Support" FontSize="11" Foreground="#505050"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content -->
                <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#0A0A0A"/>
            </Grid>
        </Grid>
    </Border>
</Window>
