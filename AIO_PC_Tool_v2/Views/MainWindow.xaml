<Window x:Class="AIO_PC_Tool_v2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JGoode's AIO PC Tool v2" 
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1A1A1A">
            <StackPanel Margin="20,24,20,32">
                <TextBlock Text="JGoode's" FontSize="14" Foreground="#A3A3A3"/>
                <TextBlock Text="AIO PC Tool" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                <TextBlock Text="v4.0" FontSize="12" Foreground="#737373" Margin="0,4,0,0"/>
                
                <TextBlock Text="App is working!" FontSize="16" Foreground="White" Margin="0,40,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Background="#0D0D0D" Padding="32,24">
            <StackPanel>
                <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="The application loaded successfully!" FontSize="14" Foreground="#A3A3A3" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
