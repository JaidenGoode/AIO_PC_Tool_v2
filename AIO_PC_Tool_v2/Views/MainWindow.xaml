<Window x:Class="AIO_PC_Tool_v2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JGoode's AIO PC Tool" 
        Height="850" Width="1400"
        MinHeight="650" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#080808"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#202020" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#0A0A0A">
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Border Width="12" Height="12" CornerRadius="6" Background="#E53935" Margin="0,0,10,0"/>
                    <TextBlock Text="JGOODE'S" FontSize="11" Foreground="#E53935" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" AIO PC TOOL" FontSize="11" Foreground="#505050" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="─" Click="Minimize_Click" Style="{StaticResource WindowButtonStyle}" Width="46" Height="40"/>
                    <Button Content="□" Click="Maximize_Click" Style="{StaticResource WindowButtonStyle}" Width="46" Height="40"/>
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource CloseButtonStyle}" Width="46" Height="40"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="#0A0A0A">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Row="0" Margin="20,24,20,28">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="42" Height="42" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E53935" Offset="0"/>
                                            <GradientStop Color="#C62828" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="15" FontWeight="Bold">
                                        <Run Text="JGoode" Foreground="White"/>
                                        <Run Text="'s" Foreground="#E53935"/>
                                    </TextBlock>
                                    <TextBlock Text="PC OPTIMIZER" FontSize="9" Foreground="#404040" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Nav -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="12,0">
                                <TextBlock Text="MAIN" FontSize="10" Foreground="#353535" FontWeight="Bold" Margin="8,0,0,8"/>
                                <Button x:Name="NavDashboard" Click="NavButton_Click" Tag="Dashboard" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="14" Width="24"/>
                                        <TextBlock Text="Dashboard" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavCleaner" Click="NavButton_Click" Tag="Cleaner" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧹" FontSize="14" Width="24"/>
                                        <TextBlock Text="System Cleaner" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavTweaks" Click="NavButton_Click" Tag="Tweaks" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" FontSize="14" Width="24"/>
                                        <TextBlock Text="Optimizations" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavUtilities" Click="NavButton_Click" Tag="Utilities" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔧" FontSize="14" Width="24"/>
                                        <TextBlock Text="Utilities" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                
                                <TextBlock Text="NETWORK" FontSize="10" Foreground="#353535" FontWeight="Bold" Margin="8,20,0,8"/>
                                <Button x:Name="NavDns" Click="NavButton_Click" Tag="Dns" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌐" FontSize="14" Width="24"/>
                                        <TextBlock Text="DNS Manager" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                
                                <TextBlock Text="SYSTEM" FontSize="10" Foreground="#353535" FontWeight="Bold" Margin="8,20,0,8"/>
                                <Button x:Name="NavRestore" Click="NavButton_Click" Tag="Restore" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="↺" FontSize="14" Width="24"/>
                                        <TextBlock Text="Restore Points" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavSettings" Click="NavButton_Click" Tag="Settings" Style="{StaticResource NavButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙" FontSize="14" Width="24"/>
                                        <TextBlock Text="Settings" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="2" Margin="12,0,12,16" CornerRadius="10" Padding="14" Cursor="Hand">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#151515" Offset="0"/>
                                    <GradientStop Color="#101010" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Join Discord" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Get support" FontSize="10" Foreground="#404040"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Content -->
                <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#080808"/>
            </Grid>
        </Grid>
    </Border>
</Window>
