<Window x:Class="AIO_PC_Tool_v2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JGoode's AIO PC Tool v2" 
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        WindowStyle="None"
        AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#1F1F1F" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#0F0F0F">
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="#DC2626" Margin="0,0,8,0"/>
                    <TextBlock Text="JGOODE A.I.O PC TOOL" FontSize="11" Foreground="#808080" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="─" Click="Minimize_Click" Style="{StaticResource WindowButtonStyle}" Width="46" Height="40"/>
                    <Button Content="□" Click="Maximize_Click" Style="{StaticResource WindowButtonStyle}" Width="46" Height="40"/>
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource CloseButtonStyle}" Width="46" Height="40"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="#0F0F0F" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Row="0" Margin="20,20,20,30">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="32" Height="32" Fill="#DC2626"/>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock FontSize="14" Foreground="White" FontWeight="Bold">
                                        <Run Text="JGoode"/>
                                        <Run Text="'s" Foreground="#DC2626"/>
                                    </TextBlock>
                                    <TextBlock Text="A.I.O PC TOOL" FontSize="10" Foreground="#606060" FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="#DC262620" CornerRadius="4" Padding="8,4" Margin="0,12,0,0" HorizontalAlignment="Left">
                                <TextBlock Text="★ ADMINISTRATOR" FontSize="9" Foreground="#DC2626" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <!-- Navigation -->
                        <StackPanel Grid.Row="1" Margin="8,0">
                            <TextBlock Text="MAIN" FontSize="10" Foreground="#505050" FontWeight="Bold" Margin="12,0,0,8"/>
                            <Button x:Name="NavDashboard" Click="NavButton_Click" Tag="Dashboard" Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊞" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavCleaner" Click="NavButton_Click" Tag="Cleaner" Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧹" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="PC Cleaner"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavTweaks" Click="NavButton_Click" Tag="Tweaks" Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Tweaks"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavUtilities" Click="NavButton_Click" Tag="Utilities" Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Utilities"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="NETWORK" FontSize="10" Foreground="#505050" FontWeight="Bold" Margin="12,20,0,8"/>
                            <Button x:Name="NavDns" Click="NavButton_Click" Tag="Dns" Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌐" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="DNS Manager"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="SYSTEM" FontSize="10" Foreground="#505050" FontWeight="Bold" Margin="12,20,0,8"/>
                            <Button x:Name="NavRestore" Click="NavButton_Click" Tag="Restore" Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↺" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Restore"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavSettings" Click="NavButton_Click" Tag="Settings" Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Settings"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Footer -->
                        <StackPanel Grid.Row="2" Margin="20,0,20,16">
                            <Border Background="#1A1A1A" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Join Discord" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="Community &amp; Support" FontSize="10" Foreground="#606060"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content -->
                <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#0A0A0A"/>
            </Grid>
        </Grid>
    </Border>
</Window>
