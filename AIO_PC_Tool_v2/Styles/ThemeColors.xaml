<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         AIO PC TOOL v2 - THEME SYSTEM
         Default: Red accent on Black background (Dark Mode)
         
         ACCENT COLORS AVAILABLE:
         - Red (Default)
         - Blue
         - Purple
         - Pink/Magenta
         - Teal/Cyan
         - Green
         - Orange
         - Gold
         ═══════════════════════════════════════════════════════════════════════════════ -->
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         DARK MODE BACKGROUNDS (Default)
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <Color x:Key="BackgroundDarkColor">#0A0A0C</Color>
    <Color x:Key="BackgroundCardColor">#121216</Color>
    <Color x:Key="BackgroundCardHoverColor">#1A1A1F</Color>
    <Color x:Key="BackgroundElevatedColor">#161619</Color>
    <Color x:Key="BackgroundInputColor">#0D0D10</Color>
    <Color x:Key="BackgroundSidebarColor">#0E0E11</Color>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         TEXT COLORS
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <Color x:Key="TextPrimaryColor">#FAFAFA</Color>
    <Color x:Key="TextSecondaryColor">#A1A1AA</Color>
    <Color x:Key="TextMutedColor">#71717A</Color>
    <Color x:Key="TextDisabledColor">#52525B</Color>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         BORDER COLORS
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <Color x:Key="BorderSubtleColor">#1F1F23</Color>
    <Color x:Key="BorderActiveColor">#2D2D33</Color>
    <Color x:Key="BorderFocusColor">#3F3F46</Color>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         ACCENT COLORS - RED (DEFAULT THEME)
         These are overwritten at runtime when user changes accent
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <Color x:Key="AccentPrimaryColor">#EF4444</Color>
    <Color x:Key="AccentPrimaryHoverColor">#F87171</Color>
    <Color x:Key="AccentPrimaryDarkColor">#DC2626</Color>
    <Color x:Key="AccentPrimaryLightColor">#FCA5A5</Color>
    <Color x:Key="AccentPrimarySubtleColor">#7F1D1D</Color>
    <Color x:Key="AccentSecondaryColor">#F97316</Color>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         STATUS COLORS (Fixed - Don't change with theme)
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="SuccessDarkColor">#16A34A</Color>
    <Color x:Key="SuccessLightColor">#166534</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningDarkColor">#D97706</Color>
    <Color x:Key="WarningLightColor">#92400E</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="ErrorDarkColor">#DC2626</Color>
    <Color x:Key="ErrorLightColor">#991B1B</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="InfoDarkColor">#2563EB</Color>
    <Color x:Key="InfoLightColor">#1E40AF</Color>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         CATEGORY COLORS (For Tweaks) - Vibrant and distinct
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <Color x:Key="PrivacyColor">#10B981</Color>
    <Color x:Key="PerformanceColor">#3B82F6</Color>
    <Color x:Key="GamingColor">#A855F7</Color>
    <Color x:Key="SystemColor">#06B6D4</Color>
    <Color x:Key="NetworkColor">#F97316</Color>
    <Color x:Key="ServicesColor">#EC4899</Color>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         SOLID BRUSHES
         ═══════════════════════════════════════════════════════════════════════════════ -->
    
    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BackgroundDark" Color="{DynamicResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="BackgroundCard" Color="{DynamicResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundCardHover" Color="{DynamicResource BackgroundCardHoverColor}"/>
    <SolidColorBrush x:Key="BackgroundElevated" Color="{DynamicResource BackgroundElevatedColor}"/>
    <SolidColorBrush x:Key="BackgroundInput" Color="{DynamicResource BackgroundInputColor}"/>
    <SolidColorBrush x:Key="BackgroundSidebar" Color="{DynamicResource BackgroundSidebarColor}"/>
    
    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimary" Color="{DynamicResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{DynamicResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{DynamicResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDisabled" Color="{DynamicResource TextDisabledColor}"/>
    
    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BorderSubtle" Color="{DynamicResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderActive" Color="{DynamicResource BorderActiveColor}"/>
    <SolidColorBrush x:Key="BorderFocus" Color="{DynamicResource BorderFocusColor}"/>
    
    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentPrimary" Color="{DynamicResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryHover" Color="{DynamicResource AccentPrimaryHoverColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryDark" Color="{DynamicResource AccentPrimaryDarkColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryLight" Color="{DynamicResource AccentPrimaryLightColor}"/>
    <SolidColorBrush x:Key="AccentPrimarySubtle" Color="{DynamicResource AccentPrimarySubtleColor}"/>
    <SolidColorBrush x:Key="AccentSecondary" Color="{DynamicResource AccentSecondaryColor}"/>
    
    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessGreen" Color="{DynamicResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessGreenDark" Color="{DynamicResource SuccessDarkColor}"/>
    <SolidColorBrush x:Key="SuccessGreenLight" Color="{DynamicResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="WarningOrange" Color="{DynamicResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningOrangeDark" Color="{DynamicResource WarningDarkColor}"/>
    <SolidColorBrush x:Key="WarningOrangeLight" Color="{DynamicResource WarningLightColor}"/>
    <SolidColorBrush x:Key="ErrorRed" Color="{DynamicResource ErrorColor}"/>
    <SolidColorBrush x:Key="ErrorRedDark" Color="{DynamicResource ErrorDarkColor}"/>
    <SolidColorBrush x:Key="ErrorRedLight" Color="{DynamicResource ErrorLightColor}"/>
    <SolidColorBrush x:Key="InfoBlue" Color="{DynamicResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoBlueDark" Color="{DynamicResource InfoDarkColor}"/>
    <SolidColorBrush x:Key="InfoBlueLight" Color="{DynamicResource InfoLightColor}"/>
    
    <!-- Category Brushes -->
    <SolidColorBrush x:Key="PrivacyBrush" Color="{DynamicResource PrivacyColor}"/>
    <SolidColorBrush x:Key="PerformanceBrush" Color="{DynamicResource PerformanceColor}"/>
    <SolidColorBrush x:Key="GamingBrush" Color="{DynamicResource GamingColor}"/>
    <SolidColorBrush x:Key="SystemBrush" Color="{DynamicResource SystemColor}"/>
    <SolidColorBrush x:Key="NetworkBrush" Color="{DynamicResource NetworkColor}"/>
    <SolidColorBrush x:Key="ServicesBrush" Color="{DynamicResource ServicesColor}"/>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         GRADIENT BRUSHES
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource AccentPrimaryColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource AccentSecondaryColor}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource BackgroundCardColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource BackgroundElevatedColor}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource BackgroundSidebarColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource BackgroundDarkColor}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Preset Gradients for visual variety -->
    <LinearGradientBrush x:Key="RedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EF4444" Offset="0"/>
        <GradientStop Color="#F97316" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="PurpleGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A855F7" Offset="0"/>
        <GradientStop Color="#6366F1" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="GreenGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="PinkGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EC4899" Offset="0"/>
        <GradientStop Color="#A855F7" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="TealGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#14B8A6" Offset="0"/>
        <GradientStop Color="#3B82F6" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="OrangeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F97316" Offset="0"/>
        <GradientStop Color="#FBBF24" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="GoldGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FBBF24" Offset="0"/>
        <GradientStop Color="#F59E0B" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ═══════════════════════════════════════════════════════════════════════════════
         SHADOW EFFECTS
         ═══════════════════════════════════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="CardShadow" Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
    <DropShadowEffect x:Key="ElevatedShadow" Color="Black" BlurRadius="30" ShadowDepth="2" Opacity="0.5"/>
    <DropShadowEffect x:Key="ButtonShadow" Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
    
    <!-- Accent Glow Effects -->
    <DropShadowEffect x:Key="AccentGlow" Color="{DynamicResource AccentPrimaryColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
    <DropShadowEffect x:Key="SuccessGlow" Color="#22C55E" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
    <DropShadowEffect x:Key="ErrorGlow" Color="#EF4444" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
    
</ResourceDictionary>
