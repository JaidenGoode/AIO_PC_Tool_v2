<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme with Red Accent (Default) -->
    <Color x:Key="BackgroundMainColor">#0D0D0D</Color>
    <Color x:Key="BackgroundCardColor">#1A1A1A</Color>
    <Color x:Key="BackgroundCardHoverColor">#252525</Color>
    <Color x:Key="BackgroundInputColor">#2A2A2A</Color>
    <Color x:Key="AccentPrimaryColor">#DC2626</Color>
    <Color x:Key="AccentSecondaryColor">#EF4444</Color>
    <Color x:Key="AccentTertiaryColor">#FCA5A5</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#A3A3A3</Color>
    <Color x:Key="TextMutedColor">#737373</Color>
    <Color x:Key="BorderDefaultColor">#333333</Color>
    <Color x:Key="SuccessGreenColor">#22C55E</Color>
    <Color x:Key="WarningOrangeColor">#F97316</Color>
    <Color x:Key="ErrorRedColor">#EF4444</Color>
    <Color x:Key="InfoBlueColor">#3B82F6</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundMain" Color="{DynamicResource BackgroundMainColor}"/>
    <SolidColorBrush x:Key="BackgroundCard" Color="{DynamicResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundCardHover" Color="{DynamicResource BackgroundCardHoverColor}"/>
    <SolidColorBrush x:Key="BackgroundInput" Color="{DynamicResource BackgroundInputColor}"/>
    <SolidColorBrush x:Key="AccentPrimary" Color="{DynamicResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentSecondary" Color="{DynamicResource AccentSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentTertiary" Color="{DynamicResource AccentTertiaryColor}"/>
    <SolidColorBrush x:Key="TextPrimary" Color="{DynamicResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{DynamicResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{DynamicResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderDefault" Color="{DynamicResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="SuccessGreen" Color="{DynamicResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="WarningOrange" Color="{DynamicResource WarningOrangeColor}"/>
    <SolidColorBrush x:Key="WarningOrangeLight" Color="#FFF7ED"/>
    <SolidColorBrush x:Key="ErrorRed" Color="{DynamicResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="InfoBlue" Color="{DynamicResource InfoBlueColor}"/>

    <!-- Category Colors -->
    <SolidColorBrush x:Key="CategoryPrivacy" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="CategoryPerformance" Color="#3B82F6"/>
    <SolidColorBrush x:Key="CategoryGaming" Color="#22C55E"/>
    <SolidColorBrush x:Key="CategoryVisual" Color="#EC4899"/>
    <SolidColorBrush x:Key="CategoryNetwork" Color="#F97316"/>
    <SolidColorBrush x:Key="CategoryPower" Color="#EAB308"/>
    <SolidColorBrush x:Key="CategorySecurity" Color="#EF4444"/>
    <SolidColorBrush x:Key="CategoryStorage" Color="#06B6D4"/>

</ResourceDictionary>
